<UserControl x:Class="ProyectoIntegradorNet10.UserControls.VentasUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border" Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <!-- Content display (non-editable mode) -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>
                            <!-- Editable text box (editable mode) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     BorderThickness="0"
                                     FontSize="{TemplateBinding FontSize}"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     Visibility="Collapsed"
                                     IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- Dropdown toggle button -->
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Width="28"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand"
                                          Style="{x:Null}">
                                <TextBlock Text="▼" FontSize="8"
                                           Foreground="{DynamicResource SectionLabelColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <!-- Dropdown list -->
                            <Popup x:Name="PART_Popup" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}">
                                    <Border Background="{DynamicResource POscuro2}"
                                            BorderBrush="{DynamicResource SeparatorColor}"
                                            BorderThickness="1" CornerRadius="8" Padding="4">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="FormCheckBox">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Check mark box -->
                            <Border x:Name="CheckMark"
                                    Width="20" Height="20"
                                    CornerRadius="4"
                                    Background="{DynamicResource InputBgBrush}"
                                    BorderBrush="{DynamicResource InputBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckIcon"
                                           Text="✓" FontSize="12" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <!-- Label text -->
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckMark" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── LEFT: Product Gallery ─── -->
        <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="8"
                        Padding="8,0" Height="34" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtBuscarProducto"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource NavTextColor}"
                                 FontSize="13" VerticalAlignment="Center"
                                 TextChanged="txtBuscarProducto_TextChanged"/>
                        <TextBlock IsHitTestVisible="False" Margin="8,0"
                                   Text="Buscar producto..." Foreground="{DynamicResource SectionLabelColor}" FontSize="13"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtBuscarProducto}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                    </Grid>
                </Border>

                <!-- ─── FAMILY SEARCH ─── -->
                <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                        Padding="10,0" Margin="0,0,0,4" Height="28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtBuscarFamiliaVenta"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource NavTextColor}"
                                 FontSize="11" VerticalAlignment="Center"
                                 TextChanged="TxtBuscarFamiliaVenta_TextChanged"/>
                        <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                    </Grid>
                </Border>

                <!-- ─── FAMILY FILTER CHIPS ─── -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Auto" Margin="0,0,0,6">
                    <WrapPanel x:Name="pnlFiltroFamiliasVenta" Orientation="Horizontal">
                        <Border x:Name="chipTodasVenta" CornerRadius="12" Padding="10,3" Cursor="Hand"
                                Background="{DynamicResource AcentoBrush}" Margin="0,0,4,3"
                                MouseLeftButtonDown="ChipFamiliaVenta_Click" Tag="-1">
                            <TextBlock Text="Todas" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>

                <!-- Product cards grid -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="icProductos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ProductoModel}">
                                <Border Width="160" Margin="0,0,10,10"
                                        Background="{DynamicResource POscuro2}"
                                        CornerRadius="10"
                                        BorderBrush="{DynamicResource SeparatorColor}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="ProductCard_Click">
                                    <StackPanel>
                                        <Border Width="160" Height="160"
                                                Background="{DynamicResource FOscuro1}"
                                                CornerRadius="10,10,0,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Url}"
                                                       Stretch="UniformToFill"
                                                       Width="160" Height="160"/>
                                                <TextBlock Text="📦" FontSize="28"
                                                           Foreground="{DynamicResource NavTextColor}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Url}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="8,6,8,8">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource NavTextColor}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PrecioDisplay, StringFormat='Bs {0}'}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource NavTextColor}"/>
                                            <TextBlock Text="{Binding StockDisplay, StringFormat='Stock: {0}'}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SectionLabelColor}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ─── Separator ─── -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

        <!-- ─── RIGHT: Sale Form ─── -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Datos de la Venta" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                    <!-- Cliente -->
                    <TextBlock Text="Cliente *" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbCliente" Style="{StaticResource FormComboBox}"
                              SelectedValuePath="Ci"
                              TextSearch.TextPath="NombreCompleto"
                              IsEditable="True" StaysOpenOnEdit="True"
                              IsTextSearchEnabled="False"
                              SelectionChanged="CmbCliente_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Ci}"
                                               FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NombreCompleto}"
                                               FontSize="13" Foreground="{DynamicResource NavTextColor}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Tipo -->
                    <TextBlock Text="Tipo de Venta" Style="{StaticResource FormLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="rbContado" GroupName="TipoGroup" Content="Contado"
                                     IsChecked="True" Foreground="{DynamicResource NavTextColor}"
                                     FontSize="13" Margin="0,0,20,0" Cursor="Hand"
                                     Checked="Tipo_Checked"/>
                        <RadioButton x:Name="rbPlanPago" GroupName="TipoGroup" Content="Plan de pago"
                                     Foreground="{DynamicResource NavTextColor}"
                                     FontSize="13" Cursor="Hand"
                                     Checked="Tipo_Checked"/>
                    </StackPanel>

                    <!-- Meses (Plan de pago) -->
                    <StackPanel x:Name="panelMeses" Visibility="Collapsed">
                        <TextBlock Text="Meses" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtMeses" Style="{StaticResource FormTextBox}" Text="1"/>
                    </StackPanel>

                    <!-- Descuento -->
                    <TextBlock Text="Descuento (%)" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDescuento" Style="{StaticResource FormTextBox}" Text="0"
                             TextChanged="OnFormChanged"/>

                    <!-- NIT -->
                    <TextBlock Text="NIT" Style="{StaticResource FormLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtNit" Style="{StaticResource FormTextBox}" Text=""/>
                        <Button Grid.Column="1" x:Name="btnTraerNitCliente"
                                Width="36" Height="36" Padding="0" Margin="6,0,0,10"
                                Background="{DynamicResource SeparatorColor}"
                                Foreground="{DynamicResource NavTextColor}"
                                BorderThickness="0" FontSize="16" Cursor="Hand"
                                ToolTip="Usar NIT del cliente"
                                Click="BtnTraerNitCliente_Click">
                            <TextBlock Text="📋" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Fecha / Hora Entrega -->
                    <TextBlock Text="Fecha de Entrega" Style="{StaticResource FormLabel}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource InputBgBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="0" Height="36">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Date picker -->
                                <DatePicker x:Name="dpFechaEntrega" Grid.Column="0"
                                            Height="34" FontSize="13" Margin="4,0,0,0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource NavTextColor}"
                                            BorderThickness="0"
                                            DisplayDateStart="{x:Static sys:DateTime.Today}"/>
                                <!-- Separator line -->
                                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource SeparatorColor}"
                                           Margin="4,6,4,6" Opacity="0.4"/>
                                <!-- Time text box -->
                                <TextBox x:Name="txtHoraEntrega" Grid.Column="2"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         CaretBrush="{DynamicResource NavTextColor}"
                                         FontSize="13" Width="60"
                                         VerticalAlignment="Center" Text=""
                                         ToolTip="Formato HH:mm (ej: 14:30)"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" x:Name="btnHoyEntrega" Style="{StaticResource ActionButton}"
                                Height="36" FontSize="12" Padding="14,0" Margin="8,0,0,0"
                                ToolTip="Establecer fecha y hora actual"
                                Click="BtnHoyEntrega_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" Margin="0,0,6,0" FontSize="13"/>
                                <TextBlock Text="Ahora"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Estado (delivery status) -->
                    <TextBlock Text="Estado de Entrega" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbEstado" Style="{StaticResource FormComboBox}" Margin="0,0,0,6">
                        <ComboBoxItem Content="Pedido" IsSelected="True"/>
                        <ComboBoxItem Content="En ruta"/>
                        <ComboBoxItem Content="Incidencia"/>
                        <ComboBoxItem Content="Completado"/>
                    </ComboBox>

                    <!-- Delivery -->
                    <CheckBox x:Name="chkDelivery" Content="Requiere Delivery"
                              Style="{StaticResource FormCheckBox}"
                              IsChecked="False"/>

                    <!-- Pagado -->
                    <CheckBox x:Name="chkPagado" Content="Pagado"
                              Style="{StaticResource FormCheckBox}"
                              IsChecked="False"
                              Checked="OnPagadoEntregadoChanged"
                              Unchecked="OnPagadoEntregadoChanged"/>

                    <!-- Entregado -->
                    <CheckBox x:Name="chkEntregado" Content="Entregado"
                              Style="{StaticResource FormCheckBox}"
                              IsChecked="False"
                              Checked="OnPagadoEntregadoChanged"
                              Unchecked="OnPagadoEntregadoChanged"/>

                    <!-- Marcar Completado (visible only when Pagado + Entregado are both checked) -->
                    <Button x:Name="btnMarcarCompletado"
                            Background="#27AE60"
                            Foreground="White" BorderThickness="0"
                            Padding="16,8" FontSize="13" FontWeight="Bold"
                            Cursor="Hand" Height="38"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            Click="BtnMarcarCompletado_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✅" Margin="0,0,8,0" FontSize="16"/>
                            <TextBlock Text="Marcar como Completado" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <!-- ─── Selected Products List ─── -->
                    <TextBlock Text="Productos en la venta" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" Margin="0,8,0,8"/>

                    <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="0"
                            MaxHeight="200" Margin="0,0,0,10">
                        <ListBox x:Name="lstProductos" Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource NavTextColor}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" Margin="0,1"
                                            Background="{DynamicResource FOscuro1}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProductoNombre}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource NavTextColor}"/>
                                                <TextBlock Text="{Binding PrecioUnitario, StringFormat='Bs {0:N2} c/u'}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SectionLabelColor}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Cant:" FontSize="9"
                                                           Foreground="{DynamicResource SectionLabelColor}"/>
                                                <TextBlock Text="{Binding Cantidad}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{DynamicResource NavTextColor}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SubtotalDisplay}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{DynamicResource NavTextColor}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="✕"
                                                       Foreground="#E74C3C" FontSize="13"
                                                       Cursor="Hand" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       MouseDown="RemoveProducto_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Cantidad selector -->
                    <Border x:Name="panelCantidad" Background="{DynamicResource POscuro2}"
                            CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="txtSelectedProductName" Text=""
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                                <TextBlock x:Name="txtSelectedProductPrice" Text=""
                                           FontSize="11"
                                           Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Width="28" Height="28" Padding="0"
                                        Background="{DynamicResource SeparatorColor}"
                                        Foreground="{DynamicResource NavTextColor}"
                                        BorderThickness="0"
                                        FontSize="14" FontWeight="Bold"
                                        Cursor="Hand" Margin="0,0,4,0"
                                        Click="BtnCantidadMenos_Click">
                                    <TextBlock Text="−" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <TextBox x:Name="txtCantidad" Text="1"
                                         Width="40" Height="28" Padding="2"
                                         Background="{DynamicResource InputBgBrush}"
                                         Foreground="{DynamicResource NavTextColor}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1"
                                         FontSize="13" FontWeight="Bold"
                                         HorizontalAlignment="Center"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         TextChanged="OnFormChanged"/>
                                <Button Width="28" Height="28" Padding="0"
                                        Background="{DynamicResource SeparatorColor}"
                                        Foreground="{DynamicResource NavTextColor}"
                                        BorderThickness="0"
                                        FontSize="14" FontWeight="Bold"
                                        Cursor="Hand" Margin="4,0,0,0"
                                        Click="BtnCantidadMas_Click">
                                    <TextBlock Text="+" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Add product button -->
                    <Button x:Name="btnAgregarProducto" Style="{StaticResource ActionButton}"
                            Click="BtnAgregarProducto_Click"
                            Visibility="Collapsed" Margin="0,0,0,10"
                            HorizontalAlignment="Stretch" Height="36">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="＋" Margin="0,0,6,0"/>
                            <TextBlock Text="Agregar a la venta"/>
                        </StackPanel>
                    </Button>

                    <!-- ─── Total ─── -->
                    <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,10"
                            Margin="0,4,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Total" FontSize="13"
                                           Foreground="{DynamicResource SectionLabelColor}"/>
                                <TextBlock x:Name="txtItemsCount" Text="0 productos"
                                           FontSize="11"
                                           Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="txtTotal" Text="Bs 0.00"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ─── Action buttons ─── -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click"
                                HorizontalAlignment="Stretch" Height="40" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" Margin="0,0,6,0"/>
                                <TextBlock Text="Guardar Venta"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnCancelar" Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click"
                                Height="40">
                            <TextBlock Text="Cancelar"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
