<UserControl x:Class="ProyectoIntegradorNet10.UserControls.FamiliaUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="FamiliaUC_Loaded">

    <UserControl.Resources>
        <!-- ─── Card template for families ─── -->
        <DataTemplate DataType="{x:Type models:FamiliaModel}">
            <Border Width="210" Margin="0,0,16,16"
                    Background="{DynamicResource POscuro2}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    MouseLeftButtonDown="Card_MouseLeftButtonDown">
                <StackPanel>
                    <!-- Image section -->
                    <Border Width="210" Height="210"
                            Background="{DynamicResource FOscuro1}"
                            CornerRadius="12,12,0,0"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Url}"
                                   Stretch="UniformToFill"
                                   Width="210" Height="210"/>
                            <TextBlock Text="📁" FontSize="40"
                                       Foreground="{DynamicResource NavTextColor}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Info section -->
                    <StackPanel Margin="12,10,12,12">
                        <!-- Name -->
                        <TextBlock Text="{Binding Nombre}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   Margin="0,0,0,4"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Description -->
                        <TextBlock Text="{Binding Descripcion}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   MaxHeight="32"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Descripcion}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Member count -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="👥 " FontSize="11"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MiembroCount, StringFormat={}{0} producto(s)}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── TOOLBAR ─── -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Familias" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtBuscarFamilia"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="TxtBuscarFamilia_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar familia..." Foreground="{DynamicResource SectionLabelColor}" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscarFamilia}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="4,0"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Click="BtnNuevaFamilia_Click" Height="36" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Padding="16,8"
                                        Background="{DynamicResource AcentoBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"
                                                   Foreground="White"/>
                                        <TextBlock Text="Nueva" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="3" Click="BtnRefrescarFamilia_Click" Height="36" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Padding="16,8"
                                        Background="{DynamicResource AcentoBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"
                                                   Foreground="White"/>
                                        <TextBlock Text="Refrescar" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ─── CARD GRID ─── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <!-- Empty state -->
                    <TextBlock x:Name="txtEmptyFamilias" Text="No hay familias registradas."
                               Foreground="{DynamicResource SectionLabelColor}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Margin="0,40,0,0"/>

                    <!-- Family cards -->
                    <ItemsControl x:Name="icFamilias">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,16"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
