<UserControl x:Class="ProyectoIntegradorNet10.UserControls.FamiliaUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="FamiliaUC_Loaded">

    <UserControl.Resources>
        <!-- ─── Card template for families ─── -->
        <DataTemplate DataType="{x:Type models:FamiliaModel}">
            <Border Width="210" Margin="0,0,16,16"
                    Background="{DynamicResource POscuro2}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    MouseLeftButtonDown="Card_MouseLeftButtonDown"
                    Effect="{DynamicResource CardShadow}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect" Value="{DynamicResource CardHoverShadow}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border Width="210" Height="210"
                            Background="{DynamicResource FOscuro1}"
                            CornerRadius="12,12,0,0"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Url}"
                                   Stretch="UniformToFill"
                                   Width="210" Height="210"/>
                            <TextBlock Text="📁" FontSize="40"
                                       Foreground="{DynamicResource NavTextColor}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <StackPanel Margin="12,10,12,12">
                        <TextBlock Text="{Binding Nombre}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   Margin="0,0,0,4"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{Binding Descripcion}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"
                                   MaxHeight="32"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Descripcion}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{Binding MiembroCount, StringFormat={}{0} producto(s)}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SectionLabelColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── TOOLBAR (matches Productos tab exactly) ─── -->
        <Border Grid.Row="0" Background="{DynamicResource FOscuro1}" 
                CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="10"
                            Background="{DynamicResource GridHeaderBrush}"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="📁" FontSize="18" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Familias" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock x:Name="txtFamiliaCount" 
                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                   Text="Cargando..."/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                        Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="txtBuscarFamilia"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource NavTextColor}"
                                     FontSize="13" VerticalAlignment="Center"
                                     TextChanged="TxtBuscarFamilia_TextChanged"/>
                            <TextBlock IsHitTestVisible="False" Margin="8,0"
                                       Text="Buscar familia..." Foreground="{DynamicResource SectionLabelColor}" FontSize="13"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txtBuscarFamilia}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform"
                              Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent"
                              Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                    </Grid>
                </Border>

                <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevaFamilia_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                        <TextBlock Text="Nueva" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ─── CARD GRID ─── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Border x:Name="panelEmptyFamilias" Visibility="Collapsed"
                        Background="Transparent" Margin="0,40,0,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="16"
                                Background="{DynamicResource GridRowHoverBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="📁" FontSize="28"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtEmptyFamilias" Text="No hay familias registradas."
                                   Foreground="{DynamicResource NavTextColor}" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Cree una familia de productos"
                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="icFamilias">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,16"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
