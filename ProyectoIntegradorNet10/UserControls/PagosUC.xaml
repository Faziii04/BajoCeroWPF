<UserControl x:Class="ProyectoIntegradorNet10.UserControls.PagosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border" Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <!-- Content display (non-editable mode) -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>
                            <!-- Editable text box (editable mode) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     Foreground="{TemplateBinding Foreground}"
                                     BorderThickness="0"
                                     FontSize="{TemplateBinding FontSize}"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     Visibility="Collapsed"
                                     IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- Dropdown toggle button -->
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Width="28"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand"
                                          Style="{x:Null}">
                                <TextBlock Text="▼" FontSize="8"
                                           Foreground="{DynamicResource SectionLabelColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}">
                                    <Border Background="{DynamicResource POscuro2}"
                                            BorderBrush="{DynamicResource SeparatorColor}"
                                            BorderThickness="1" CornerRadius="8" Padding="4">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SuccessButton">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E8449"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── TOP: Venta Header + Summary ─── -->
        <Border Grid.Row="0" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Venta info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,10,0">
                        <TextBlock Text="💳" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtPagoVentaInfo" Text="Seleccione una venta"
                                   Foreground="{DynamicResource NavTextColor}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtPagoVentaTotal" Text=""
                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Summary chips -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total: " Foreground="{DynamicResource SectionLabelColor}" FontSize="12"/>
                            <TextBlock x:Name="txtSummaryTotal" Text="Bs 0.00"
                                       Foreground="{DynamicResource NavTextColor}" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pagado: " Foreground="{DynamicResource SectionLabelColor}" FontSize="12"/>
                            <TextBlock x:Name="txtSummaryPagado" Text="Bs 0.00"
                                       Foreground="#27AE60" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pendiente: " Foreground="{DynamicResource SectionLabelColor}" FontSize="12"/>
                            <TextBlock x:Name="txtSummaryPendiente" Text="Bs 0.00"
                                       Foreground="#E67E22" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnGenerarPagos" Style="{StaticResource ActionButton}"
                            Click="BtnGenerarPagos_Click" Visibility="Collapsed" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" Margin="0,0,6,0"/>
                            <TextBlock Text="Generar Cuotas"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnRefrescarPagos" Style="{StaticResource SecondaryButton}"
                            Click="BtnRefrescarPagos_Click" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── MID: Pagos DataGrid ─── -->
        <Border Grid.Row="1" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="0" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource POscuro2}"
                        CornerRadius="12,12,0,0" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pagos de la Venta" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="txtPagoCount" Text="0 pagos"
                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" x:Name="dgPagos" Style="{StaticResource GridStyle}"
                          SelectionChanged="dgPagos_SelectionChanged"
                          MaxHeight="240">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding PagoId}" Width="50"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="100"/>
                        <DataGridTextColumn Header="Monto" Binding="{Binding MontoDisplay}" Width="100"/>
                        <DataGridTextColumn Header="Método" Binding="{Binding Metodo}" Width="100"/>
                        <DataGridTemplateColumn Header="Estado" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,2" Margin="4,0"
                                            Background="{Binding Estado, Converter={x:Null}}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Estado}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ─── BOTTOM: Pago Form + Actions ─── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Pago form -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Gestión de Pagos" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtPagoSubtitle" Text="Seleccione un pago o cree uno nuevo"
                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left column: Monto + Metodo -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Monto (Bs)" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtPagoMonto" Style="{StaticResource FormTextBox}"/>

                                <TextBlock Text="Método" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="cmbPagoMetodo" Style="{StaticResource FormComboBox}">
                                    <ComboBoxItem Content="Efectivo"/>
                                    <ComboBoxItem Content="Transferencia"/>
                                    <ComboBoxItem Content="QR"/>
                                    <ComboBoxItem Content="Tarjeta"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Right column: Estado -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Estado" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="cmbPagoEstado" Style="{StaticResource FormComboBox}">
                                    <ComboBoxItem Content="Pendiente"/>
                                    <ComboBoxItem Content="Pagado"/>
                                    <ComboBoxItem Content="Vencido"/>
                                </ComboBox>

                                <Button x:Name="btnMarcarPagado" Style="{StaticResource SuccessButton}"
                                        Click="BtnMarcarPagado_Click"
                                        Visibility="Collapsed" Margin="0,8,0,0" Height="40"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="✅" Margin="0,0,8,0" FontSize="16"/>
                                        <TextBlock Text="Marcar Venta como Pagada" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Action buttons row -->
                        <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,10" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="btnNuevoPago" Style="{StaticResource ActionButton}" Click="BtnNuevoPago_Click"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" Margin="0,0,6,0"/>
                                        <TextBlock Text="Nuevo Pago"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnGuardarPago" Style="{StaticResource ActionButton}" Click="BtnGuardarPago_Click"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="txtBtnGuardarPago" Text="Guardar Pago"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnEliminarPago" Style="{StaticResource DangerButton}" Click="BtnEliminarPago_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                        <TextBlock Text="Eliminar"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

            <!-- RIGHT: Factura section + Help -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Factura section -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Factura" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="btnGenerarFactura" Style="{StaticResource ActionButton}"
                                    Click="BtnGenerarFactura_Click"
                                    Visibility="Collapsed" Height="38"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="📄" Margin="0,0,8,0" FontSize="14"/>
                                    <TextBlock Text="Generar Factura" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Border x:Name="panelFacturaInfo" Background="{DynamicResource POscuro2}"
                                    CornerRadius="8" Padding="12,10" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="txtFacturaInfo" Text=""
                                           Foreground="{DynamicResource AcentoBrush}"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Selected pago info -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="ℹ️" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Información" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="12,10">
                                <TextBlock x:Name="txtPagoSelectedInfo"
                                           Text="Seleccione un pago para gestionar"
                                           Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
