<UserControl x:Class="ProyectoIntegradorNet10.UserControls.InsumosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="ScrollBar"><Setter Property="Width" Value="8"/><Setter Property="Background" Value="Transparent"/></Style>
        <Style TargetType="Thumb"><Setter Property="Background" Value="{DynamicResource SeparatorColor}"/><Setter Property="BorderThickness" Value="0"/></Style>

        <DataTemplate x:Key="CardTemplate">
            <Border Width="240" Margin="0,0,12,12"
                    Background="{DynamicResource POscuro2}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    MouseLeftButtonDown="CardInsumo_Click">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="6" CornerRadius="12,12,0,0"
                            Background="{DynamicResource AcentoBrush}"/>

                    <StackPanel Grid.Row="1" Margin="14,10,14,12">
                        <TextBlock Text="{Binding Nombre}" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>

                        <!-- Price + Stock row -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding PrecioDisplay, StringFormat='Bs {0}'}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource AcentoBrush}"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="6,2"
                                    Background="{DynamicResource FOscuro1}">
                                <TextBlock Text="{Binding StockDisplay, StringFormat='Stock: {0}'}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource SeparatorColor}"
                                Opacity="0.3" Margin="0,0,0,4"/>

                        <StackPanel Visibility="{Binding UnidadMedida, Converter={x:Null}}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UnidadMedida}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        <DataTrigger Binding="{Binding UnidadMedida}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock FontSize="11" Foreground="{DynamicResource SectionLabelColor}" Margin="0,0,0,2">
                                <Run Text="Unidad: " FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}"/>
                                <Run Text="{Binding UnidadMedida}"/>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Visibility="{Binding Descripcion, Converter={x:Null}}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Descripcion}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        <DataTrigger Binding="{Binding Descripcion}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Background="{DynamicResource FOscuro1}" CornerRadius="6" Padding="8,6" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Descripcion}" FontSize="12" FontStyle="Italic"
                                           Foreground="{DynamicResource NavTextColor}"
                                           TextTrimming="CharacterEllipsis" MaxHeight="36"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Insumos" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8" Margin="0,0,16,0" Padding="4,0" Height="34" MaxWidth="300" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="txtBuscar" Style="{x:Null}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource NavTextColor}" FontSize="13" VerticalAlignment="Center" TextChanged="TxtBuscar_TextChanged"/>
                            <TextBlock Grid.Column="0" IsHitTestVisible="False" Margin="8,0" Text="Buscar insumo..." Foreground="#888" FontSize="13" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                            </TextBlock>
                            <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="2" x:Name="btnNuevo" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/><TextBlock Text="Nuevo"/></StackPanel>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/><TextBlock Text="Refrescar"/></StackPanel>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <ItemsControl x:Name="icInsumos" ItemTemplate="{StaticResource CardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock x:Name="txtEmptyState" Text="No hay insumos registrados."
                               Foreground="#888" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Margin="0,40,0,0"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
