<UserControl x:Class="ProyectoIntegradorNet10.UserControls.IncidenciasUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="8"
                        Background="#C0392B" Margin="0,0,10,0">
                    <TextBlock Text="⚠️" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Incidencias" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource NavTextColor}"/>
                    <TextBlock x:Name="txtCount" Text="" FontSize="11"
                               Foreground="{DynamicResource SectionLabelColor}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel x:Name="pnlIncidencias"/>
            </ScrollViewer>

            <!-- New incidencia form -->
            <Border Grid.Row="2" Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="Nueva Incidencia" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtMotivo" Background="{DynamicResource InputBgBrush}"
                             Foreground="{DynamicResource NavTextColor}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             Padding="8,5" FontSize="12" Margin="0,0,0,6"
                             TextWrapping="Wrap" MinHeight="28"
                             CaretBrush="{DynamicResource NavTextColor}"/>
                    <TextBox x:Name="txtNotas" Background="{DynamicResource InputBgBrush}"
                             Foreground="{DynamicResource NavTextColor}"
                             BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                             Padding="8,5" FontSize="12" Margin="0,0,0,8"
                             TextWrapping="Wrap" MinHeight="50"
                             CaretBrush="{DynamicResource NavTextColor}"/>
                    <Button x:Name="btnAgregar" Style="{StaticResource DangerButton}"
                            Click="BtnAgregar_Click" HorizontalAlignment="Stretch" Height="34">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="➕" Margin="0,0,6,0"/>
                            <TextBlock Text="Registrar Incidencia"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
