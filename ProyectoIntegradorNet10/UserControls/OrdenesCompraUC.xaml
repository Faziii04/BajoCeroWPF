<UserControl x:Class="ProyectoIntegradorNet10.UserControls.OrdenesCompraUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="ScrollBar"><Setter Property="Width" Value="8"/><Setter Property="Background" Value="Transparent"/></Style>
        <Style TargetType="Thumb"><Setter Property="Background" Value="{DynamicResource SeparatorColor}"/><Setter Property="BorderThickness" Value="0"/></Style>

        <DataTemplate x:Key="CardTemplate">
            <Border Width="300" Margin="0,0,12,12"
                    Background="{DynamicResource POscuro2}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    MouseLeftButtonDown="CardOrden_Click">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                    <!-- Estado color bar -->
                    <Border Grid.Row="0" Height="6" CornerRadius="12,12,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Estado}" Value="Pedido">
                                        <Setter Property="Background" Value="#F39C12"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Recibido">
                                        <Setter Property="Background" Value="#27AE60"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Cancelado">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="14,10,14,12">
                        <!-- Header: ID + Estado badge -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource SectionLabelColor}">
                                <Run Text="#"/><Run Text="{Binding Id}"/>
                            </TextBlock>
                            <Border Grid.Column="1" CornerRadius="8" Padding="8,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Pedido">
                                                <Setter Property="Background" Value="#F39C12"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Recibido">
                                                <Setter Property="Background" Value="#27AE60"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Cancelado">
                                                <Setter Property="Background" Value="#E74C3C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>

                        <!-- Proveedor -->
                        <TextBlock Text="{Binding ProveedorNombre}" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>

                        <Border Height="1" Background="{DynamicResource SeparatorColor}" Opacity="0.3" Margin="0,0,0,6"/>

                        <!-- Fecha/Hora Pedido -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <Path Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"
                                  Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.2" Fill="Transparent"
                                  Data="M3,3 L17,3 L17,17 L3,17 Z M3,7 L17,7 M6,1 L6,5 M14,1 L14,5"
                                  VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource NavTextColor}">
                                <Run Text="Pedido: "/>
                                <Run FontWeight="SemiBold" Text="{Binding FechaPedidoDisplay, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run FontWeight="SemiBold" Text="{Binding HoraPedidoDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Fecha/Hora Llegada (if set) -->
                        <StackPanel Orientation="Horizontal" Visibility="{Binding FechaLlegada, Converter={x:Null}}" Margin="0,0,0,2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FechaLlegada}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="14" Height="14" Margin="0,0,6,0" Stretch="Uniform"
                                  Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.2" Fill="Transparent"
                                  Data="M17,3 L17,17 L3,17 L3,3 M7,1 L7,5 M13,1 L13,5 M3,7 L17,7"
                                  VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource NavTextColor}">
                                <Run Text="Llegada: "/>
                                <Run FontWeight="SemiBold" Text="{Binding FechaLlegadaDisplay, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run FontWeight="SemiBold" Text="{Binding HoraLlegadaDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Quick action buttons -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" x:Name="pnlQuickButtons">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Pedido">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </StackPanel.Style>
                                <Button Content="✅ Recibido" FontSize="10" Height="26" Padding="8,0" Margin="0,0,4,0"
                                        Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="BtnQuickRecibido_Click" Tag="{Binding}"/>
                                <Button Content="❌ Cancelar" FontSize="10" Height="26" Padding="8,0"
                                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="BtnQuickCancelar_Click" Tag="{Binding}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="6" Padding="8,4">
                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AcentoBrush}">
                                    <Run Text="Total: "/>
                                    <Run Text="{Binding MontoDisplay, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

            <!-- TOOLBAR -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                    <!-- Row 0: Title + main actions -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Órdenes de Compra" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8" Margin="0,0,16,0" Padding="4,0" Height="34" MaxWidth="250" HorizontalAlignment="Left">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="txtBuscar" Style="{x:Null}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource NavTextColor}" FontSize="13" VerticalAlignment="Center" TextChanged="TxtBuscar_TextChanged"/>
                                <TextBlock Grid.Column="0" IsHitTestVisible="False" Margin="8,0" Text="Buscar orden..." Foreground="#888" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                                <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="2" x:Name="btnNuevo" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/><TextBlock Text="Nuevo"/></StackPanel>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Click="BtnRefrescar_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/><TextBlock Text="Refrescar"/></StackPanel>
                        </Button>
                    </Grid>

                    <!-- Row 1: Filters -->
                    <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                        <ComboBox x:Name="cmbEstadoFilter" Width="130" Margin="0,0,8,0" Height="32" SelectionChanged="CmbEstadoFilter_SelectionChanged">
                            <ComboBoxItem Content="Todos" IsSelected="True"/>
                            <ComboBoxItem Content="Pedido"/>
                            <ComboBoxItem Content="Recibido"/>
                            <ComboBoxItem Content="Cancelado"/>
                        </ComboBox>
                        <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="8,0" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Llegada desde:" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpLlegadaDesde" Height="28" FontSize="12" SelectedDateChanged="DpFilter_SelectedDateChanged"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="8,0" Height="32">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="hasta:" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpLlegadaHasta" Height="28" FontSize="12" SelectedDateChanged="DpFilter_SelectedDateChanged"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- CARDS -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <ItemsControl x:Name="icOrdenes" ItemTemplate="{StaticResource CardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock x:Name="txtEmptyState" Text="No hay órdenes de compra registradas."
                               Foreground="#888" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" Margin="0,40,0,0"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
