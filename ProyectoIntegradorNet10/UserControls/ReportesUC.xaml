<UserControl x:Class="ProyectoIntegradorNet10.UserControls.ReportesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow" ShadowDepth="2" Opacity="0.15" BlurRadius="12" Direction="270"/>

        <Style TargetType="Button" x:Key="ReportTypeButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource GridRowSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="OutlineButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorColor}"/>
        </Style>
        <Style TargetType="CalendarItem">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        </Style>
        <Style TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsToday" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CalendarButton">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="14" 
                    Padding="20,14" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="{DynamicResource GridHeaderBrush}" Margin="0,0,12,0">
                            <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reportes" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock x:Name="txtReportCount" Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                       Text="Seleccione un reporte"/>
                        </StackPanel>
                    </StackPanel>


                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnExportar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource POscuro2}" CornerRadius="14" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource GridHeaderBrush}" 
                                CornerRadius="14,14,0,0" Padding="16,14">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="6" Height="6" CornerRadius="3" Background="#FFFFFF" Opacity="0.6"
                                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Tipo de reporte" FontSize="13" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,6,0,6">
                            <StackPanel>
                                <!-- VENTAS -->
                                <TextBlock Text="VENTAS" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,10,16,4"/>
                                <Button x:Name="btnIngresos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Ingresos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="📊" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Ingresos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Dinero por día" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnVentas" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Ventas" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="💰" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Ventas" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Por período" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnFacturacion" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Facturacion" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="🧾" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Facturación" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Facturas emitidas" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- INVENTARIO -->
                                <TextBlock Text="INVENTARIO" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>
                                <Button x:Name="btnProductos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Productos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="📦" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Productos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Más vendidos" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnInventario" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Inventario" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Stock Actual" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Inventario" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnDepositos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Depositos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="🏭" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Depósitos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Stock por depósito" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- PRODUCCIÓN -->
                                <TextBlock Text="PRODUCCIÓN" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>
                                <Button x:Name="btnProduccion" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Produccion" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="🏗️" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Producción" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Estado y costos" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="btnOrdenes" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Ordenes" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="📑" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Órdenes Compra" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Pedidos a proveedores" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- CLIENTES -->
                                <TextBlock Text="CLIENTES" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>
                                <Button x:Name="btnClientes" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Clientes" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="👥" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Clientes" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Frecuencia de compra" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- LOGÍSTICA -->
                                <TextBlock Text="LOGÍSTICA" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>
                                <Button x:Name="btnVehiculos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Vehiculos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="🚛" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Vehículos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Flota y SOAT" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- RRHH -->
                                <TextBlock Text="RRHH" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>
                                <Button x:Name="btnEmpleados" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Empleados" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="👤" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Empleados" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Por área y rol" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.2" RadiusX="1"/>

                <!-- RIGHT: Data + Chart -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Report header -->
                    <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="14,14,0,0" 
                            Padding="20,14" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="reportIconBorder" Width="36" Height="36" CornerRadius="10"
                                        Background="{DynamicResource GridHeaderBrush}" Margin="0,0,12,0">
                                    <TextBlock x:Name="txtReportIcon" Text="📊" FontSize="16" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtReportTitle" Text="Seleccione un reporte" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock x:Name="txtReportSubtitle" Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                               Text="Elija una opción del panel izquierdo"/>
                                </StackPanel>
                            </StackPanel>
                            <Border x:Name="badgeLoading" Grid.Column="2" Background="{DynamicResource AcentoBrush}" 
                                    CornerRadius="6" Padding="10,4" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⟳" FontSize="12" Foreground="White" Margin="0,0,6,0"/>
                                    <TextBlock Text="Cargando..." Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Date filter -->
                    <Border x:Name="dateFilterBar" Grid.Row="1" Background="{DynamicResource POscuro2}"
                            Padding="14,8" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8"
                                    BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1.5"
                                    Padding="10,0" Height="32">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Desde:" Foreground="{DynamicResource SectionLabelColor}"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <DatePicker x:Name="dpDesde" BorderThickness="0" Background="Transparent"
                                                Width="120" SelectedDateChanged="DpFilter_SelectedDateChanged"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="→" Foreground="{DynamicResource SectionLabelColor}"
                                       FontSize="14" VerticalAlignment="Center" Margin="8,0"/>
                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8"
                                    BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1.5"
                                    Padding="10,0" Height="32">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Hasta:" Foreground="{DynamicResource SectionLabelColor}"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <DatePicker x:Name="dpHasta" BorderThickness="0" Background="Transparent"
                                                Width="120" SelectedDateChanged="DpFilter_SelectedDateChanged"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource OutlineButton}" Margin="8,0,0,0" Click="BtnLimpiarFiltros_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕" Margin="0,0,5,0" FontSize="11"/>
                                    <TextBlock Text="Limpiar"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- KPI Cards -->
                    <Border x:Name="kpiBar" Grid.Row="2" Background="{DynamicResource POscuro2}"
                            Padding="16,10" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="10" Padding="14,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock x:Name="kpiLabel1" Text="Total" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                                    <TextBlock x:Name="kpiValue1" Text="—" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="10" Padding="14,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock x:Name="kpiLabel2" Text="Promedio" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                                    <TextBlock x:Name="kpiValue2" Text="—" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource FOscuro1}" CornerRadius="10" Padding="14,10">
                                <StackPanel>
                                    <TextBlock x:Name="kpiLabel3" Text="Registros" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                                    <TextBlock x:Name="kpiValue3" Text="—" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Chart area (WPF-native bar chart) -->
                    <Border x:Name="chartBar" Grid.Row="3" Background="{DynamicResource POscuro2}"
                            Height="240" Visibility="Collapsed" Padding="16,12,16,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="chartTitle" Grid.Row="0" Text="Ingresos por día" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,8"/>
                            <Canvas x:Name="chartCanvas" Grid.Row="1" Background="Transparent" ClipToBounds="True"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <Border Grid.Row="4" Background="{DynamicResource POscuro2}" CornerRadius="0,0,14,14" Padding="0">
                        <Grid>
                            <DataGrid x:Name="dgReportes" Style="{StaticResource GridStyle}"/>

                            <Border x:Name="emptyState" Visibility="Visible" Background="{DynamicResource POscuro2}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="18"
                                            Background="{DynamicResource GridRowHoverBrush}"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Seleccione un tipo de reporte" 
                                               Foreground="{DynamicResource NavTextColor}" FontSize="16" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Elija una opción del panel izquierdo para visualizar" 
                                               Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
