<UserControl x:Class="ProyectoIntegradorNet10.UserControls.ReportesUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- ════════════════════════════════════════ -->
        <!--  MODERN STYLES                          -->
        <!-- ════════════════════════════════════════ -->

        <!-- Card shadow effect -->
        <DropShadowEffect x:Key="CardShadow" ShadowDepth="2" Opacity="0.15" BlurRadius="12" Direction="270"/>

        <!-- Sidebar button style -->
        <Style TargetType="Button" x:Key="ReportTypeButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Effect="{x:Null}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource GridRowSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="1" Opacity="0.2" BlurRadius="6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="2" Opacity="0.3" BlurRadius="8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary outline button -->
        <Style TargetType="Button" x:Key="OutlineButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="44"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </UserControl.Resources>

    <!-- ════════════════════════════════════════ -->
    <!--  MAIN LAYOUT                            -->
    <!-- ════════════════════════════════════════ -->
    <Border Background="{DynamicResource FOscuro1}" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOP BAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="14" 
                    Padding="20,14" Margin="0,0,0,20"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title section -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="{DynamicResource GridHeaderBrush}"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reportes" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock x:Name="txtReportCount" 
                                       Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                       Text="Seleccione un reporte para comenzar"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Date filters -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8" 
                                BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1.5"
                                Padding="10,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Desde:" Foreground="{DynamicResource SectionLabelColor}" 
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="dpDesde" SelectedDateChanged="DpDesde_SelectedDateChanged" 
                                            BorderThickness="0" Background="Transparent" Width="120"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="→" Foreground="{DynamicResource SectionLabelColor}" 
                                   FontSize="14" VerticalAlignment="Center" Margin="8,0"/>
                        <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8" 
                                BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1.5"
                                Padding="10,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Hasta:" Foreground="{DynamicResource SectionLabelColor}" 
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="dpHasta" SelectedDateChanged="DpHasta_SelectedDateChanged" 
                                            BorderThickness="0" Background="Transparent" Width="120"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="btnLimpiarFiltros" Style="{StaticResource OutlineButton}" 
                                Margin="8,0,0,0" Click="BtnLimpiarFiltros_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" Margin="0,0,5,0" FontSize="11"/>
                                <TextBlock Text="Limpiar"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Export button -->
                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnExportar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: Report type selector ─── -->
                <Border Grid.Column="0" Background="{DynamicResource POscuro2}" CornerRadius="14"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Sidebar header -->
                        <Border Grid.Row="0" Background="{DynamicResource GridHeaderBrush}" 
                                CornerRadius="14,14,0,0" Padding="16,14">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="6" Height="6" CornerRadius="3" Background="#FFFFFF" Opacity="0.6"
                                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Tipo de reporte" FontSize="13" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Sidebar buttons -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,6,0,6">
                            <StackPanel>
                                <!-- INVENTARIO group -->
                                <TextBlock Text="INVENTARIO" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,10,16,4"/>

                                <Button x:Name="btnProductos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Productos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="📦" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Productos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Más vendidos" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button x:Name="btnInventario" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Inventario" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Inventario" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Stock actual" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button x:Name="btnDepositos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Depositos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="🏭" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Depósitos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Stock por depósito" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- CLIENTES group -->
                                <TextBlock Text="CLIENTES" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>

                                <Button x:Name="btnClientes" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Clientes" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="👥" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Clientes" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Frecuencia de compra" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- VENTAS group -->
                                <TextBlock Text="VENTAS" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>

                                <Button x:Name="btnVentas" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Ventas" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="💰" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Ventas" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Por período" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button x:Name="btnFacturacion" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Facturacion" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="🧾" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Facturación" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Facturas emitidas" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- RRHH group -->
                                <TextBlock Text="RRHH" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>

                                <Button x:Name="btnEmpleados" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Empleados" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="👤" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Empleados" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Por área y rol" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button x:Name="btnRoles" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Roles" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="🔐" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Roles" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Permisos y usuarios" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- LOGÍSTICA group -->
                                <TextBlock Text="LOGÍSTICA" Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="10" FontWeight="Bold" Margin="16,14,16,4"/>

                                <Button x:Name="btnVehiculos" Style="{StaticResource ReportTypeButton}" 
                                        Click="BtnReporte_Click" Tag="Vehiculos" Margin="6,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                Background="{DynamicResource GridRowHoverBrush}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="🚛" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Vehículos" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Flota y SOAT" FontSize="10" Opacity="0.55"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ─── Separator ─── -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.2" RadiusX="1"/>

                <!-- ─── RIGHT: Data display ─── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Report header -->
                    <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="14,14,0,0" 
                            Padding="20,14" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="reportIconBorder" Width="36" Height="36" CornerRadius="10"
                                        Background="{DynamicResource GridHeaderBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock x:Name="txtReportIcon" Text="📊" FontSize="16" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtReportTitle" Text="Seleccione un reporte" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock x:Name="txtReportSubtitle" 
                                               Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                               Text="Elija una opción del panel izquierdo"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Loading spinner -->
                                <Border x:Name="badgeLoading" Background="{DynamicResource AcentoBrush}" 
                                        CornerRadius="6" Padding="10,4" Visibility="Collapsed"
                                        Effect="{StaticResource CardShadow}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⟳" FontSize="12" Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="Cargando..." Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- KPI Summary bar (visible when data loaded) -->
                    <Border x:Name="kpiBar" Grid.Row="1" Background="{DynamicResource POscuro2}" 
                            Padding="20,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Background="{DynamicResource GridRowHoverBrush}" CornerRadius="8" Padding="14,6" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="kpiCount" Foreground="{DynamicResource NavTextColor}"
                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource GridRowHoverBrush}" CornerRadius="8" Padding="14,6" Margin="0,0,10,0"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💰" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="kpiTotal" Foreground="{DynamicResource NavTextColor}"
                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid area -->
                    <Border Grid.Row="2" Background="{DynamicResource POscuro2}" CornerRadius="0,0,14,14" Padding="0">
                        <Grid>
                            <DataGrid x:Name="dgReportes" Style="{StaticResource GridStyle}" 
                                      SelectionChanged="DgReportes_SelectionChanged">
                            </DataGrid>

                            <!-- Empty state -->
                            <Border x:Name="emptyState" Visibility="Visible" Background="{DynamicResource POscuro2}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="18"
                                            Background="{DynamicResource GridRowHoverBrush}"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Seleccione un tipo de reporte" 
                                               Foreground="{DynamicResource NavTextColor}" FontSize="16" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Elija una opción del panel izquierdo para visualizar los datos" 
                                               Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
