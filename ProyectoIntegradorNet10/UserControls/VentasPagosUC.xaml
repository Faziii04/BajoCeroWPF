<UserControl x:Class="ProyectoIntegradorNet10.UserControls.VentasPagosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="VentasPagosUC_Loaded">

    <UserControl.Resources>
        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton" x:Key="TabRadioStyle">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Ventas y Pagos" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtBuscar"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="txtBuscar_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar venta..." Foreground="#888" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="4,0"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ TAB SELECTOR ════════ -->
            <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,8" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbVentas" GroupName="TabGroup" IsChecked="True"
                                 Style="{StaticResource TabRadioStyle}" Content="Ventas"
                                 Checked="Tab_Checked"/>
                    <RadioButton x:Name="rbPagos" GroupName="TabGroup" IsChecked="False"
                                 Style="{StaticResource TabRadioStyle}" Content="Pagos"
                                 Checked="Tab_Checked"/>
                </StackPanel>
            </Border>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="2">

                <!-- ─── VENTAS TAB ─── -->
                <Grid x:Name="gridVentasTab" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: DataGrid -->
                    <Border Grid.Column="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                        <Grid>
                            <DataGrid x:Name="dgVentas" Style="{StaticResource GridStyle}"
                                      SelectionChanged="dgVentas_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="90"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="txtEmptyState" Text="No hay ventas registradas."
                                       Foreground="#888" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

                    <!-- RIGHT: Venta Detail Form -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <Border Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Datos de Venta" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                                <!-- Cliente (editable ComboBox - type to filter, select from dropdown) -->
                                <TextBlock Text="Cliente *" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="cmbCliente" Style="{StaticResource FormComboBox}"
                                          DisplayMemberPath="NombreCompleto" SelectedValuePath="Ci"
                                          IsEditable="True" StaysOpenOnEdit="True"
                                          Loaded="cmbCliente_Loaded"/>

                                <!-- Tipo: Contado / Plan de pago -->
                                <TextBlock Text="Tipo" Style="{StaticResource FormLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton x:Name="rbContado" GroupName="TipoGroup" Content="Contado"
                                                 IsChecked="True" Foreground="{DynamicResource NavTextColor}"
                                                 FontSize="13" Margin="0,0,20,0" Cursor="Hand"
                                                 Checked="Tipo_Checked"/>
                                    <RadioButton x:Name="rbPlanPago" GroupName="TipoGroup" Content="Plan de pago"
                                                 Foreground="{DynamicResource NavTextColor}"
                                                 FontSize="13" Cursor="Hand"
                                                 Checked="Tipo_Checked"/>
                                </StackPanel>

                                <!-- Meses (visible only for Plan de pago) -->
                                <StackPanel x:Name="panelMeses" Visibility="Collapsed">
                                    <TextBlock Text="Meses" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtMeses" Style="{StaticResource FormTextBox}" Text="1"/>
                                </StackPanel>

                                <!-- Descuento -->
                                <TextBlock Text="Descuento (%)" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtDescuento" Style="{StaticResource FormTextBox}" Text="0"
                                         TextChanged="CalcularTotal"/>

                                <!-- Productos section -->
                                <TextBlock Text="Productos" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}" Margin="0,8,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbProducto" Grid.Column="0" Style="{StaticResource FormComboBox}"
                                              DisplayMemberPath="Nombre" SelectedValuePath="Id"
                                              Margin="0,0,8,10"
                                              SelectionChanged="cmbProducto_SelectionChanged"/>
                                    <Button Grid.Column="1" Style="{StaticResource ActionButton}"
                                            Height="36" Width="36" Padding="0" Margin="0,0,0,10"
                                            Click="BtnAgregarProducto_Click">
                                        <TextBlock Text="＋" FontSize="16"/>
                                    </Button>
                                </Grid>

                                <!-- Productos added list -->
                                <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="8"
                                        Margin="0,0,0,10" MaxHeight="160">
                                    <ListBox x:Name="lstProductos" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource NavTextColor}"
                                             SelectionChanged="lstProductos_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ProductoNombre}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Cantidad}"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding SubtotalDisplay}"
                                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="3" Text="✕" Foreground="#E74C3C"
                                                               Cursor="Hand" VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               MouseDown="RemoveProducto_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <!-- Cantidad input for selected product (visible when product selected in combo) -->
                                <StackPanel x:Name="panelCantidad" Visibility="Collapsed">
                                    <TextBlock Text="Cantidad a agregar" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtCantidad" Style="{StaticResource FormTextBox}" Text="1"
                                             TextChanged="txtCantidad_TextChanged"/>
                                </StackPanel>

                                <!-- Total -->
                                <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="12,8" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Total:" FontSize="16" FontWeight="Bold"
                                                   Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="txtTotal" Text="0.00" FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource AcentoBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="btnGuardarVenta" Style="{StaticResource ActionButton}" Click="BtnGuardarVenta_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💾" Margin="0,0,6,0"/>
                                            <TextBlock Text="Guardar"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnEliminarVenta" Style="{StaticResource DangerButton}" Click="BtnEliminarVenta_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                            <TextBlock Text="Eliminar"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnCancelarVenta" Style="{StaticResource SecondaryButton}" Click="BtnCancelarVenta_Click">
                                        <TextBlock Text="Cancelar"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>

                <!-- ─── PAGOS TAB (REDESIGNED) ─── -->
                <Grid x:Name="gridPagosTab" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TOP: Filters bar -->
                    <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search by client name -->
                            <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                                    Padding="8,0" Height="34" Margin="0,0,16,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="txtPagoSearch"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource NavTextColor}"
                                                 FontSize="13" VerticalAlignment="Center"
                                                 TextChanged="txtPagoSearch_TextChanged"/>
                                        <TextBlock IsHitTestVisible="False" Margin="8,0"
                                                   Text="Buscar por cliente..." Foreground="#888" FontSize="13"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=txtPagoSearch}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </Border>

                            <!-- Tipo filter -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Tipo:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <RadioButton x:Name="rbFiltroTodos" GroupName="FiltroTipo" Content="Todos"
                                             IsChecked="True" Foreground="{DynamicResource NavTextColor}"
                                             FontSize="13" Margin="0,0,12,0" Cursor="Hand"
                                             Checked="FiltroTipo_Checked"/>
                                <RadioButton x:Name="rbFiltroContado" GroupName="FiltroTipo" Content="Contado"
                                             Foreground="{DynamicResource NavTextColor}"
                                             FontSize="13" Margin="0,0,12,0" Cursor="Hand"
                                             Checked="FiltroTipo_Checked"/>
                                <RadioButton x:Name="rbFiltroPlan" GroupName="FiltroTipo" Content="Plan de pago"
                                             Foreground="{DynamicResource NavTextColor}"
                                             FontSize="13" Cursor="Hand"
                                             Checked="FiltroTipo_Checked"/>
                            </StackPanel>

                            <!-- Refresh button -->
                            <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnRefrescarPagos_Click"
                                    Height="34">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Refrescar"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- BOTTOM: Ventas list + Pago form -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Filtered Ventas DataGrid -->
                        <Border Grid.Column="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Selected venta info -->
                                <Border Grid.Row="0" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                                        Padding="12,8" Margin="10,10,10,0">
                                    <StackPanel>
                                        <TextBlock x:Name="txtPagoVentaInfo" Text="Seleccione una venta"
                                                   Foreground="{DynamicResource NavTextColor}" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtPagoVentaTotal" Text="" Foreground="{DynamicResource NavTextColor}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <DataGrid Grid.Row="1" x:Name="dgVentasPagos" Style="{StaticResource GridStyle}"
                                          Margin="0,10,0,0"
                                          SelectionChanged="dgVentasPagos_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                        <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="90"/>
                                        <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="90"/>
                                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock x:Name="txtPagosEmpty" Text="No se encontraron ventas."
                                           Foreground="#888" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <!-- Separator -->
                        <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

                        <!-- RIGHT: Pago Form -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Gestión de Pagos" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                                    <!-- Generar pagos (Plan de pago) -->
                                    <Button x:Name="btnGenerarPagos" Style="{StaticResource ActionButton}"
                                            Click="BtnGenerarPagos_Click" Margin="0,0,0,16"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" Margin="0,0,6,0"/>
                                            <TextBlock Text="Generar Pagos del Plan"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Pagos DataGrid for selected venta -->
                                    <TextBlock Text="Pagos de la Venta" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,6"/>
                                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="0"
                                            MaxHeight="160" Margin="0,0,0,12">
                                        <DataGrid x:Name="dgPagos" Style="{StaticResource GridStyle}"
                                                  SelectionChanged="dgPagos_SelectionChanged"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  RowHeaderWidth="0"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID" Binding="{Binding PagoId}" Width="40"/>
                                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="80"/>
                                                <DataGridTextColumn Header="Monto" Binding="{Binding MontoDisplay}" Width="70"/>
                                                <DataGridTextColumn Header="Método" Binding="{Binding Metodo}" Width="70"/>
                                                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                                        <TextBlock x:Name="txtPagoSelectedInfo"
                                                   Text="Seleccione un pago para gestionar"
                                                   Foreground="{DynamicResource NavTextColor}" FontSize="13"/>
                                    </Border>

                                    <!-- Pago form fields -->
                                    <TextBlock Text="Monto" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtPagoMonto" Style="{StaticResource FormTextBox}"/>

                                    <TextBlock Text="Método" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cmbPagoMetodo" Style="{StaticResource FormComboBox}">
                                        <ComboBoxItem Content="Efectivo"/>
                                        <ComboBoxItem Content="Transferencia"/>
                                        <ComboBoxItem Content="QR"/>
                                        <ComboBoxItem Content="Tarjeta"/>
                                    </ComboBox>

                                    <TextBlock Text="Estado" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cmbPagoEstado" Style="{StaticResource FormComboBox}">
                                        <ComboBoxItem Content="Pendiente"/>
                                        <ComboBoxItem Content="Pagado"/>
                                        <ComboBoxItem Content="Vencido"/>
                                    </ComboBox>

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button x:Name="btnNuevoPago" Style="{StaticResource ActionButton}" Click="BtnNuevoPago_Click"
                                                Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="＋" Margin="0,0,6,0"/>
                                                <TextBlock Text="Nuevo Pago"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnGuardarPago" Style="{StaticResource ActionButton}" Click="BtnGuardarPago_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💾" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="txtBtnGuardarPago" Text="Guardar Pago"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="btnEliminarPago" Style="{StaticResource DangerButton}" Click="BtnEliminarPago_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                                <TextBlock Text="Eliminar"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
