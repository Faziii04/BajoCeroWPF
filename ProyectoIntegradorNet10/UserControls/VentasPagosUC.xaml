<UserControl x:Class="ProyectoIntegradorNet10.UserControls.VentasPagosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="VentasPagosUC_Loaded">

    <UserControl.Resources>
        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── ComboBox dark mode (dropdown popup) ─── -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton" x:Key="TabRadioStyle">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Date text -->
                                    <TextBox x:Name="PART_TextBox"
                                             Grid.Column="0"
                                             Background="Transparent"
                                             Foreground="{TemplateBinding Foreground}"
                                             BorderThickness="0"
                                             CaretBrush="{TemplateBinding Foreground}"
                                             FontSize="{TemplateBinding FontSize}"
                                             VerticalContentAlignment="Center"
                                             Padding="8,2"
                                             IsReadOnly="True"
                                             Text="{Binding SelectedDate, StringFormat={}{0:dd/MM/yyyy}, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <!-- Dropdown button -->
                                    <ToggleButton x:Name="PART_Button"
                                                  Grid.Column="1"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Width="24"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Cursor="Hand">
                                        <TextBlock Text="📅" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <!-- Popup / Calendar -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Grid>
                                    <Border Background="{DynamicResource POscuro2}"
                                            BorderBrush="{DynamicResource SeparatorColor}"
                                            BorderThickness="1" CornerRadius="8" Padding="4">
                                        <Calendar x:Name="PART_Calendar"
                                                  Background="{DynamicResource POscuro2}"
                                                  Foreground="{DynamicResource NavTextColor}"
                                                  BorderThickness="0"
                                                  SelectionMode="SingleDate"
                                                  SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Calendar / DatePicker popup dark mode styles ─── -->
        <Style TargetType="Calendar">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorColor}"/>
        </Style>
        <Style TargetType="CalendarItem">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        </Style>
        <Style TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsToday" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CalendarButton">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Ventas y Pagos" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1" Text="" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Nueva Venta"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="1" Grid.RowSpan="1">

                <!-- ─── VENTAS TAB ─── -->
                <Grid x:Name="gridVentasTab" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filters bar (responsive wrap) -->
                    <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,10" Margin="0,0,0,10">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Cliente -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                <TextBlock Text="Cliente:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroCliente" Height="30" FontSize="12" MinWidth="150"
                                          DisplayMemberPath="NombreCompleto"
                                          IsEditable="True" StaysOpenOnEdit="True"
                                          SelectionChanged="Filtro_Changed"
                                          Loaded="CmbFiltroCliente_Loaded"/>
                            </StackPanel>

                            <!-- Desde -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Desde:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpFechaDesde" SelectedDateChanged="Filtro_Changed"
                                            Height="30" MinWidth="120"/>
                            </StackPanel>

                            <!-- Hasta -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Hasta:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpFechaHasta" SelectedDateChanged="Filtro_Changed"
                                            Height="30" MinWidth="120"/>
                            </StackPanel>

                            <!-- Fecha Entrega Desde -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Ent. Desde:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpFechaEntregaDesde" SelectedDateChanged="Filtro_Changed"
                                            Height="30" MinWidth="110"/>
                            </StackPanel>

                            <!-- Fecha Entrega Hasta -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,2,6">
                                <TextBlock Text="Ent. Hasta:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <DatePicker x:Name="dpFechaEntregaHasta" SelectedDateChanged="Filtro_Changed"
                                            Height="30" MinWidth="110"/>
                            </StackPanel>

                            <!-- Hoy (fecha entrega) -->
                            <Button x:Name="btnHoyEntrega" Style="{StaticResource SecondaryButton}"
                                    Content="📅 Ent. Hoy" FontSize="11" Height="30"
                                    Padding="10,0" Margin="0,0,10,6"
                                    Click="BtnHoyEntrega_Click"/>

                            <!-- Hoy -->
                            <Button x:Name="btnHoy" Style="{StaticResource SecondaryButton}"
                                    Content="📅 Fecha Hoy" FontSize="11" Height="30"
                                    Padding="10,0" Margin="0,0,10,6"
                                    Click="BtnHoy_Click"/>

                            <!-- Tipo -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Tipo:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroTipo" Height="30" FontSize="12" MinWidth="100"
                                          SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Contado"/>
                                    <ComboBoxItem Content="Plan de pago"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Estado -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Estado:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroEstado" Height="30" FontSize="12" MinWidth="100"
                                          SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Pedido"/>
                                    <ComboBoxItem Content="En ruta"/>
                                    <ComboBoxItem Content="Incidencia"/>
                                    <ComboBoxItem Content="Completado"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Delivery -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Delivery:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroDelivery" Height="30" FontSize="12" MinWidth="80"
                                          SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Sí"/>
                                    <ComboBoxItem Content="No"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Pagado -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,6">
                                <TextBlock Text="Pagado:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroPagado" Height="30" FontSize="12" MinWidth="80"
                                          SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Sí"/>
                                    <ComboBoxItem Content="No"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Entregado -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Entregado:" Foreground="{DynamicResource NavTextColor}"
                                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbFiltroEntregado" Height="30" FontSize="12" MinWidth="80"
                                          SelectionChanged="Filtro_Changed">
                                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                                    <ComboBoxItem Content="Sí"/>
                                    <ComboBoxItem Content="No"/>
                                </ComboBox>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- Ventas DataGrid -->
                    <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                        <Grid>
                            <DataGrid x:Name="dgVentas" Style="{StaticResource GridStyle}"
                                      SelectionChanged="DgVentas_SelectionChanged"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="85"/>
                                    <DataGridTextColumn Header="Ent. Fecha" Binding="{Binding FechaEntregaDisplay}" Width="90"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="90"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="85"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="75"/>
                                    <DataGridTextColumn Header="Pagado" Binding="{Binding PagadoDisplay}" Width="65"/>
                                    <DataGridTextColumn Header="Entregado" Binding="{Binding EntregadoDisplay}" Width="75"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="txtEmptyState" Text="No hay ventas registradas."
                                       Foreground="{DynamicResource SectionLabelColor}" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
