<UserControl x:Class="ProyectoIntegradorNet10.UserControls.PedidosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SuccessButton">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E8449"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" x:Key="FormCombo">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="12">
            <StackPanel>
                <!-- ═══ VENTA HEADER ═══ -->
                <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="16,14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="10"
                                Background="{DynamicResource AcentoBrush}" Margin="0,0,14,0">
                            <TextBlock Text="🧾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="txtVentaTitulo" Text="" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock x:Name="txtVentaCliente" Text="" FontSize="12"
                                       Foreground="{DynamicResource SectionLabelColor}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" x:Name="badgeEstado" CornerRadius="10" Padding="12,4"
                                Background="{DynamicResource AcentoBrush}" VerticalAlignment="Center">
                            <TextBlock x:Name="txtEstadoBadge" Text="" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ DETAIL GRID ═══ -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Total" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                        <TextBlock x:Name="txtVentaTotal" Text="" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}" Margin="0,2,0,8"/>
                        <TextBlock Text="Delivery" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                        <TextBlock x:Name="txtDelivery" Text="" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Pagado" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                        <TextBlock x:Name="txtPagado" Text="" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}" Margin="0,2,0,8"/>
                        <TextBlock Text="Entregado" FontSize="10" Foreground="{DynamicResource SectionLabelColor}"/>
                        <TextBlock x:Name="txtEntregado" Text="" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ═══ ASSIGN REPARTIDOR ═══ -->
                <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,12" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="{DynamicResource AcentoBrush}" Margin="0,0,10,0">
                                <TextBlock Text="🚚" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Asignar Repartidor" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                            </StackPanel>
                        </Grid>

                        <ComboBox x:Name="cmbRepartidor" Style="{StaticResource FormCombo}"
                                  DisplayMemberPath="EmpleadoNombre" SelectedValuePath="Id"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtRepartidorActual" Text="" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SectionLabelColor}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="btnAsignarRepartidor" Style="{StaticResource ActionButton}"
                                    Click="BtnAsignarRepartidor_Click" Height="32" FontSize="12" Padding="14,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Asignar" Margin="0,0,6,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══ PRODUCTS ═══ -->
                <TextBlock Text="Productos" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,6"/>
                <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="10" MaxHeight="150"
                        Margin="0,0,0,14">
                    <ListBox x:Name="lstProductos" Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource NavTextColor}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProductoNombre}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Cantidad}" FontSize="12"
                                               Foreground="{DynamicResource SectionLabelColor}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SubtotalDisplay}" FontSize="12" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ═══ ACTIONS ═══ -->
                <Button x:Name="btnMarcarEntregado" Style="{StaticResource SuccessButton}"
                        Click="BtnMarcarEntregado_Click" HorizontalAlignment="Stretch" Height="42">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="✅" Margin="0,0,8,0" FontSize="16"/>
                        <TextBlock Text="Marcar como Entregado" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
