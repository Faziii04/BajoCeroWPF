<UserControl x:Class="ProyectoIntegradorNet10.UserControls.EmpleadosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- ─── DataGrid style ─── -->
        <Style TargetType="DataGrid" x:Key="GridStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBrush}"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ScrollViewer.PanningMode" Value="Both"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <!-- ─── DataGridColumnHeader ─── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ─── DataGridRow ─── -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── DataGridCell ─── -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- ─── TextBox style for form ─── -->
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── PasswordBox style for form ─── -->
        <Style TargetType="PasswordBox" x:Key="FormPasswordBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Form label style ─── -->
        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- ─── Action buttons ─── -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── ScrollBar style ─── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Empleados" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox Name="txtBuscar"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="txtBuscar_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar empleado..." Foreground="#888" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="4,0"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: DataGrid ─── -->
                <Border Grid.Column="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                    <Grid>
                        <DataGrid x:Name="dgEmpleados" Style="{StaticResource GridStyle}"
                                  SelectionChanged="dgEmpleados_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CI" Binding="{Binding Ci}" Width="100"/>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Apellido" Binding="{Binding Apellido}" Width="*"/>
                                <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="*"/>
                                <DataGridTextColumn Header="Área" Binding="{Binding Area}" Width="80"/>
                                <DataGridTextColumn Header="Turno" Binding="{Binding Turno}" Width="70"/>
                                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Name="txtEmptyState" Text="No hay empleados registrados."
                                   Foreground="#888" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- ─── Separator ─── -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

                <!-- ─── RIGHT: Detail Form ─── -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Datos del Empleado" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                            <!-- CI -->
                            <TextBlock Text="CI *" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtCi" Style="{StaticResource FormTextBox}"/>

                            <!-- Nombre -->
                            <TextBlock Text="Nombre *" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtNombre" Style="{StaticResource FormTextBox}"/>

                            <!-- Apellido -->
                            <TextBlock Text="Apellido *" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtApellido" Style="{StaticResource FormTextBox}"/>

                            <!-- Correo -->
                            <TextBlock Text="Correo *" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtCorreo" Style="{StaticResource FormTextBox}"/>

                            <!-- Teléfono -->
                            <TextBlock Text="Teléfono" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtTelefono" Style="{StaticResource FormTextBox}"/>

                            <!-- Dirección -->
                            <TextBlock Text="Dirección" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtDireccion" Style="{StaticResource FormTextBox}" TextWrapping="Wrap" AcceptsReturn="False" MaxHeight="60"/>

                            <!-- Área -->
                            <TextBlock Text="Área" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtArea" Style="{StaticResource FormTextBox}"/>

                            <!-- Turno -->
                            <TextBlock Text="Turno" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtTurno" Style="{StaticResource FormTextBox}"/>

                            <!-- Usuario -->
                            <TextBlock Text="Usuario *" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtUsuario" Style="{StaticResource FormTextBox}"/>

                            <!-- Contraseña -->
                            <TextBlock Text="Contraseña *" Style="{StaticResource FormLabel}"/>
                            <PasswordBox Name="txtContrasena" Style="{StaticResource FormPasswordBox}"/>

                            <!-- URL (foto) -->
                            <TextBlock Text="URL (foto)" Style="{StaticResource FormLabel}"/>
                            <TextBox Name="txtUrl" Style="{StaticResource FormTextBox}"/>

                            <!-- ═══ Roles Section ═══ -->
                            <Border Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="12" Margin="0,4,0,12">
                                <StackPanel>
                                    <TextBlock Text="Roles asignados" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,8"/>

                                    <ListBox Name="lstRoles" Background="Transparent" BorderThickness="0"
                                             Height="120" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             SelectionMode="Single"
                                             Foreground="{DynamicResource NavTextColor}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton Content="{Binding Nombre}"
                                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                             GroupName="EmpleadoRole"
                                                             Foreground="{DynamicResource NavTextColor}"
                                                             FontSize="12"
                                                             Margin="2,2"
                                                             Checked="ChkRole_CheckedChanged"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <!-- ═══ Action Buttons ═══ -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                                        <TextBlock Text="Guardar"/>
                                    </StackPanel>
                                </Button>
                                <Button Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                        <TextBlock Text="Eliminar"/>
                                    </StackPanel>
                                </Button>
                                <Button Name="btnCancelar" Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click">
                                    <TextBlock Text="Cancelar"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
