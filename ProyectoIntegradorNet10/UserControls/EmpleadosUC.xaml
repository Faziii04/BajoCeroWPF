<UserControl x:Class="ProyectoIntegradorNet10.UserControls.EmpleadosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Empleados" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox Name="txtBuscar"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="txtBuscar_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar empleado..." Foreground="{DynamicResource PlaceholderTextBrush}" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ MAIN CONTENT: Full-width DataGrid ════════ -->
            <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                <Grid>
                    <DataGrid x:Name="dgEmpleados" Style="{StaticResource GridStyle}"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionChanged="dgEmpleados_Seleccionado">
                        <DataGrid.Columns>
                            <!-- Avatar column -->
                            <DataGridTemplateColumn Header="" Width="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Width="40" Height="40" Margin="8,0,0,0">
                                            <Image x:Name="AvatarImage" Width="40" Height="40"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Source="{Binding Url}"
                                                   Visibility="Visible">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,40,40" RadiusX="8" RadiusY="8"/>
                                                </Image.Clip>
                                            </Image>
                                            <Border x:Name="InitialsBadge" Width="40" Height="40" CornerRadius="8"
                                                    Background="{DynamicResource AcentoBrush}"
                                                    Visibility="Collapsed">
                                                <TextBlock Text="{Binding Iniciales}"
                                                           Foreground="White"
                                                           FontSize="15" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter TargetName="AvatarImage" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="InitialsBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter TargetName="AvatarImage" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="InitialsBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="CI" Binding="{Binding Ci}" Width="100"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Apellido" Binding="{Binding Apellido}" Width="*"/>
                            <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="*"/>
                            <DataGridTextColumn Header="Teléfono" Binding="{Binding Telefono}" Width="120"/>
                            <DataGridTextColumn Header="Área" Binding="{Binding Area}" Width="90"/>
                            <DataGridTextColumn Header="Turno" Binding="{Binding Turno}" Width="80"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Name="txtEmptyState" Text="No hay empleados registrados."
                               Foreground="{DynamicResource PlaceholderTextBrush}" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
