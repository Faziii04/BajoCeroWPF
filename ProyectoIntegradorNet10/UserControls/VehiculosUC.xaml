<UserControl x:Class="ProyectoIntegradorNet10.UserControls.VehiculosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="VehiculosUC_Loaded">

    <UserControl.Resources>
        <!-- Card style for vehicle items -->
        <Style x:Key="VehiculoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.15" BlurRadius="6" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SOAT badge style -->
        <Style x:Key="SoatBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Filter toggle button style -->
        <Style x:Key="FilterToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dashboard card style -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" Opacity="0.1" BlurRadius="6" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Shared styles (same as other UserControls) ── -->

        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Vehículos" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>

                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtBuscar"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="txtBuscar_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar vehículo (placa, marca, modelo...)" Foreground="#888" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent" Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" x:Name="btnRepartidores" Style="{StaticResource ActionButton}" Click="BtnRepartidores_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚚" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Repartidores"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" x:Name="btnNuevo" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" x:Name="btnRefrescar" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ DASHBOARD CARDS ════════ -->
            <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource AcentoBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="🚗" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtTotalVehiculos" Text="0" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                                <TextBlock Text="Total vehículos" FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Vigentes -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource SoatVigenteBgBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="✅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSoatVigentes" Text="0" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource SoatVigenteBrush}"/>
                                <TextBlock Text="SOAT Vigentes" FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Por vencer -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource SoatPorVencerBgBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="⚠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSoatPorVencer" Text="0" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource SoatPorVencerBrush}"/>
                                <TextBlock Text="Por vencer (30d)" FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Vencidos -->
                    <Border Grid.Column="3" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" CornerRadius="10" Background="{DynamicResource SoatVencidoBgBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="❌" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtSoatVencidos" Text="0" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource SoatVencidoBrush}"/>
                                <TextBlock Text="SOAT Vencidos" FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════ FILTER TOGGLES ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="12" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filtrar:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" Margin="12,0,16,0"/>
                    <RadioButton x:Name="rbTodos" GroupName="FiltroSoat" IsChecked="True"
                                 Style="{StaticResource FilterToggleStyle}" Checked="Filtro_Checked" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Todos" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtCountTodos" Text="(0)" Foreground="{DynamicResource SectionLabelColor}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rbVigentes" GroupName="FiltroSoat"
                                 Style="{StaticResource FilterToggleStyle}" Checked="Filtro_Checked" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Vigentes" Foreground="{DynamicResource SoatVigenteBrush}"/>
                            <TextBlock x:Name="txtCountVigentes" Text=" (0)" Foreground="{DynamicResource SoatVigenteBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rbPorVencer" GroupName="FiltroSoat"
                                 Style="{StaticResource FilterToggleStyle}" Checked="Filtro_Checked" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Por vencer" Foreground="{DynamicResource SoatPorVencerBrush}"/>
                            <TextBlock x:Name="txtCountPorVencer" Text=" (0)" Foreground="{DynamicResource SoatPorVencerBrush}"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rbVencidos" GroupName="FiltroSoat"
                                 Style="{StaticResource FilterToggleStyle}" Checked="Filtro_Checked">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Vencidos" Foreground="{DynamicResource SoatVencidoBrush}"/>
                            <TextBlock x:Name="txtCountVencidos" Text=" (0)" Foreground="{DynamicResource SoatVencidoBrush}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ════════ MAIN CONTENT: Vehicle Cards + Modal Overlay ════════ -->
            <Grid Grid.Row="3">
                <!-- ─── Vehicle Cards Area ─── -->
                <Border Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="icVehiculos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" Style="{StaticResource VehiculoCardStyle}"
                                                MouseDown="Card_MouseDown">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Placa + SOAT badge -->
                                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Placa}"
                                                               FontSize="16" FontWeight="Bold"
                                                               Foreground="{DynamicResource NavTextColor}"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Style="{StaticResource SoatBadgeStyle}"
                                                            Background="{Binding SoatBadgeBgBrush}">
                                                        <TextBlock Text="{Binding SoatEstado}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="{Binding SoatColorBrush}"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Marca / Modelo -->
                                                <TextBlock Grid.Row="1" Text="{Binding MarcaModelo}"
                                                           FontSize="14" Foreground="{DynamicResource SectionLabelColor}"
                                                           Margin="0,0,0,6"/>

                                                <!-- Details row -->
                                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding Tipo}" FontSize="12"
                                                               Foreground="{DynamicResource NavTextColor}"
                                                               Margin="0,0,16,0"/>
                                                    <TextBlock Text="{Binding KilometrajeDisplay}" FontSize="12"
                                                               Foreground="{DynamicResource NavTextColor}"/>
                                                </StackPanel>

                                                <!-- SOAT vencimiento -->
                                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="SOAT: " FontSize="11"
                                                               Foreground="{DynamicResource SectionLabelColor}"/>
                                                    <TextBlock Text="{Binding SoatVencimientoDisplay}" FontSize="11"
                                                               Foreground="{DynamicResource NavTextColor}"/>
                                                </StackPanel>

                                                <!-- Repartidor asignado -->
                                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Repartidor: " FontSize="11"
                                                               Foreground="{DynamicResource SectionLabelColor}"/>
                                                    <TextBlock Text="{Binding RepartidorAsignado}" FontSize="11"
                                                               Foreground="{DynamicResource NavTextColor}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TieneRepartidorActivo}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="Sin asignar" FontSize="11"
                                                               Foreground="{DynamicResource SectionLabelColor}"
                                                               FontStyle="Italic">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TieneRepartidorActivo}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Asignar button (hidden when already assigned) -->
                                                <Button Grid.Row="5" x:Name="btnAsignarRepartidor"
                                                        Height="30" Padding="10,4" FontSize="11"
                                                        HorizontalAlignment="Stretch"
                                                        Click="BtnAsignarRepartidor_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TieneRepartidorActivo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="👤" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Asignar Repartidor"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- Desasignar button (visible only when assigned) -->
                                                <Button Grid.Row="5" x:Name="btnDesasignarRepartidor"
                                                        Height="30" Padding="10,4" FontSize="11"
                                                        HorizontalAlignment="Stretch"
                                                        Click="BtnDesasignarRepartidor_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TieneRepartidorActivo}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="✕" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Desasignar"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="txtEmptyState" Text="No hay vehículos registrados."
                                   Foreground="#888" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- ─── Modal Overlay ─── -->
                <Grid x:Name="modalOverlay" Visibility="Collapsed" Panel.ZIndex="10">
                    <!-- Semi-transparent backdrop -->
                    <Rectangle Fill="#000000" Opacity="0.4">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect Radius="4"/>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>

                    <!-- Modal panel -->
                    <Border Width="480" MaxHeight="600" Background="{DynamicResource POscuro2}"
                            CornerRadius="16" Padding="24"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Header -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtModalTitle" Grid.Column="0"
                                               Text="Nuevo Vehículo" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <Button Grid.Column="1" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            Width="30" Height="30" Click="BtnCerrarModal_Click">
                                        <TextBlock Text="✕" FontSize="18" Foreground="{DynamicResource NavTextColor}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <!-- Placa -->
                                <TextBlock Text="Placa *" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtPlaca" Style="{StaticResource FormTextBox}" MaxLength="20"/>

                                <!-- Marca -->
                                <TextBlock Text="Marca" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtMarca" Style="{StaticResource FormTextBox}" MaxLength="50"/>

                                <!-- Modelo -->
                                <TextBlock Text="Modelo" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtModelo" Style="{StaticResource FormTextBox}" MaxLength="50"/>

                                <!-- Tipo -->
                                <TextBlock Text="Tipo" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="cmbTipo"
                                          Background="{DynamicResource InputBgBrush}"
                                          Foreground="{DynamicResource NavTextColor}"
                                          BorderBrush="{DynamicResource InputBorderBrush}"
                                          BorderThickness="1"
                                          Padding="10,7"
                                          FontSize="13"
                                          Margin="0,0,0,10"
                                          SelectedIndex="0"
                                          IsEditable="True">
                                    <ComboBoxItem Content="Sedán"/>
                                    <ComboBoxItem Content="SUV"/>
                                    <ComboBoxItem Content="Camioneta"/>
                                    <ComboBoxItem Content="Furgoneta"/>
                                    <ComboBoxItem Content="Camión"/>
                                    <ComboBoxItem Content="Moto"/>
                                    <ComboBoxItem Content="Otro"/>
                                </ComboBox>

                                <!-- Kilometraje -->
                                <TextBlock Text="Kilometraje (km)" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtKilometraje" Style="{StaticResource FormTextBox}" MaxLength="10"/>

                                <!-- SOAT Vencimiento -->
                                <TextBlock Text="Vencimiento SOAT" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="dpSoatVencimiento"
                                            Background="{DynamicResource InputBgBrush}"
                                            Foreground="{DynamicResource NavTextColor}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,7"
                                            FontSize="13"
                                            Margin="0,0,0,10"
                                            SelectedDateFormat="Short"/>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💾" Margin="0,0,6,0"/>
                                            <TextBlock Text="Guardar"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                            <TextBlock Text="Eliminar"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource SecondaryButton}" Click="BtnCerrarModal_Click">
                                        <TextBlock Text="Cancelar"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
