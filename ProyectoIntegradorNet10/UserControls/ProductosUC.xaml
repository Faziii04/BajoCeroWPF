<UserControl x:Class="ProyectoIntegradorNet10.UserControls.ProductosUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="ProductosUC_Loaded">

    <UserControl.Resources>
        <DropShadowEffect x:Key="TabShadow" ShadowDepth="0" Opacity="0.12" BlurRadius="10"/>

        <!-- ─── Product card DataTemplate ─── -->
        <DataTemplate DataType="{x:Type models:ProductoModel}">
            <Border Width="210" Margin="0,0,16,16"
                    Background="{DynamicResource POscuro2}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="1"
                    Cursor="Hand"
                    MouseLeftButtonDown="Card_MouseLeftButtonDown"
                    Effect="{DynamicResource CardShadow}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect" Value="{DynamicResource CardHoverShadow}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- Image section (1:1 square) -->
                    <Border Width="210" Height="210"
                            Background="{DynamicResource FOscuro1}"
                            CornerRadius="12,12,0,0"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Url}"
                                   Stretch="UniformToFill"
                                   Width="210" Height="210"/>
                            <Border Background="{DynamicResource FOscuro1}" Opacity="0.5"
                                    Width="210" Height="210"
                                    Visibility="Collapsed">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="📦" FontSize="32"
                                       Foreground="{DynamicResource NavTextColor}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Info section -->
                    <StackPanel Margin="12,8,12,12">
                        <TextBlock Text="{Binding Nombre}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   Margin="0,0,0,4"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Bs" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SectionLabelColor}" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding PrecioDisplay}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StockDisplay, StringFormat='Stock: {0}'}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       VerticalAlignment="Center"/>
                            <Ellipse Width="6" Height="6" Margin="8,0,4,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Inactivo">
                                                <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Estado}" FontSize="10"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ─── TabControl: Dashboard-style panel ─── -->
        <Style TargetType="TabControl" x:Key="ProductTabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{DynamicResource POscuro2}"
                                CornerRadius="14"
                                Effect="{DynamicResource CardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Tab headers as inline pills -->
                                <Border Grid.Row="0" Background="Transparent"
                                        Padding="16,12,16,0">
                                    <TabPanel x:Name="HeaderPanel"
                                              IsItemsHost="True"
                                              KeyboardNavigation.TabIndex="1"/>
                                </Border>

                                <!-- Separator -->
                                <Border Grid.Row="0" Height="1"
                                        Background="{DynamicResource SeparatorColor}"
                                        Opacity="0.3"
                                        Margin="16,0,16,0"
                                        VerticalAlignment="Bottom"/>

                                <!-- Content -->
                                <Border Grid.Row="1"
                                        Background="Transparent"
                                        CornerRadius="0,0,14,14"
                                        Padding="20">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── TabItem: pill-style tabs ─── -->
        <Style TargetType="TabItem" x:Key="ProductTabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SectionLabelColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0"
                                CornerRadius="8">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource FOscuro1}" Padding="16">
        <TabControl Style="{StaticResource ProductTabControl}">
            <!-- ════════════════════════════════════════════════ -->
            <!-- TAB 1: Productos                                  -->
            <!-- ════════════════════════════════════════════════════ -->
            <TabItem Header="📦  Productos" Style="{StaticResource ProductTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ─── TOOLBAR (ReportesUC-style) ─── -->
                    <Border Grid.Row="0" Background="{DynamicResource FOscuro1}" 
                            CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                            Effect="{DynamicResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon + Title -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="10"
                                        Background="{DynamicResource GridHeaderBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="📦" FontSize="18" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Productos" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock x:Name="txtProductCount" 
                                               Foreground="{DynamicResource SectionLabelColor}" FontSize="11"
                                               Text="Cargando..."/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Search -->
                            <Border Grid.Column="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                    Margin="24,0,16,0" Padding="8,0" VerticalAlignment="Center" Height="34">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="txtBuscar"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource NavTextColor}"
                                                 FontSize="13" VerticalAlignment="Center"
                                                 TextChanged="txtBuscar_TextChanged"/>
                                        <TextBlock IsHitTestVisible="False" Margin="8,0"
                                                   Text="Buscar producto..." 
                                                   Foreground="{DynamicResource SectionLabelColor}" FontSize="13"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=txtBuscar}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" 
                                          Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" 
                                          StrokeThickness="1.5" Fill="Transparent"
                                          Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                                    <TextBlock Text="Nuevo" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⟳" FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                                    <TextBlock Text="Refrescar" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ─── FAMILY FILTER (search + pills) ─── -->
                    <Border Grid.Row="1" Background="{DynamicResource FOscuro1}" 
                            CornerRadius="10" Padding="12,6" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Family search -->
                            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                    Padding="10,0" Height="30" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtBuscarFamilia"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource NavTextColor}"
                                             FontSize="11" VerticalAlignment="Center"
                                             TextChanged="TxtBuscarFamilia_TextChanged"/>
                                    <Path Grid.Column="1" Width="14" Height="14" Margin="4,0" 
                                          Stretch="Uniform" Stroke="{DynamicResource NavTextColor}" 
                                          StrokeThickness="1.5" Fill="Transparent"
                                          Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                                </Grid>
                            </Border>

                            <!-- Family chips -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="pnlFiltroFamilias" Orientation="Horizontal">
                                    <Border x:Name="chipTodas" CornerRadius="14" Padding="14,5" Cursor="Hand"
                                            Background="{DynamicResource AcentoBrush}" Margin="0,0,6,0"
                                            MouseLeftButtonDown="ChipFamilia_Click" Tag="-1">
                                        <TextBlock Text="Todas" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </WrapPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ─── CARD GRID ─── -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <!-- Empty state -->
                            <Border x:Name="panelEmptyState" Visibility="Collapsed"
                                    Background="Transparent" Margin="0,40,0,0">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="16"
                                            Background="{DynamicResource GridRowHoverBrush}"
                                            HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="📦" FontSize="28"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="txtEmptyState" Text="No hay productos registrados."
                                               Foreground="{DynamicResource NavTextColor}" FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Agregue un producto para comenzar"
                                               Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="icProductos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,16"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- TAB 2: Familias                                     -->
            <!-- ════════════════════════════════════════════════════ -->
            <TabItem Header="📁  Familias" Style="{StaticResource ProductTabItem}">
                <local:FamiliaUC />
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
