<UserControl x:Class="ProyectoIntegradorNet10.UserControls.DistribucionUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProyectoIntegradorNet10.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="DistribucionUC_Loaded">

    <Border Background="{DynamicResource FOscuro1}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ TOOLBAR ════════ -->
            <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="16,10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="8"
                                Background="{DynamicResource AcentoBrush}" Margin="0,0,10,0">
                            <TextBlock Text="🚚" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Distribución" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock x:Name="txtVentasCount" Text=""
                                       Foreground="{DynamicResource SectionLabelColor}" FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <TextBlock Text="Desde:" Foreground="{DynamicResource NavTextColor}" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpFechaDesde" SelectedDateChanged="FiltroFecha_Changed" MinWidth="110"
                                    Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}"
                                    BorderBrush="{DynamicResource InputBorderBrush}" Height="30" FontSize="12"/>
                        <TextBlock Text="Hasta:" Foreground="{DynamicResource NavTextColor}" FontSize="11"
                                   VerticalAlignment="Center" Margin="10,0,4,0" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpFechaHasta" SelectedDateChanged="FiltroFecha_Changed" MinWidth="110"
                                    Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}"
                                    BorderBrush="{DynamicResource InputBorderBrush}" Height="30" FontSize="12"/>
                        <Button x:Name="btnHoy" Style="{StaticResource SecondaryButton}" Content="📅 Hoy"
                                FontSize="11" Padding="10,0" Margin="6,0,0,0" Height="30"
                                Click="BtnHoy_Click"/>
                    </StackPanel>

                    <Button Grid.Column="3" Style="{StaticResource ActionButton}" Click="BtnRefrescar_Click"
                            ToolTip="Recargar lista" Height="34">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Refrescar" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ════════ ADVANCED FILTERS: Sin repartidor + Cliente + Repartidor ════════ -->
            <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="12,8" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sin repartidor chip toggle -->
                    <Border x:Name="chipSinRepartidor" CornerRadius="14" Padding="14,5" Cursor="Hand"
                            Background="{DynamicResource GridRowHoverBrush}"
                            MouseLeftButtonDown="ChipSinRepartidor_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="iconSinRepartidor" Text="◻" FontSize="12" Margin="0,0,6,0"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock Text="Sin repartidor" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Cliente search -->
                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8"
                            Padding="8,0" Height="30" Margin="12,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtBuscarCliente"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource NavTextColor}"
                                     FontSize="12" VerticalAlignment="Center"
                                     TextChanged="FiltroCliente_TextChanged"/>
                            <TextBlock IsHitTestVisible="False" Margin="8,0"
                                       Text="Buscar cliente..." Foreground="{DynamicResource SectionLabelColor}" FontSize="12"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txtBuscarCliente}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Path Grid.Column="1" Width="14" Height="14" Margin="4,0"
                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                  StrokeThickness="1.5" Fill="Transparent"
                                  Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                        </Grid>
                    </Border>

                    <!-- Repartidor filter label -->
                    <TextBlock Grid.Column="2" Text="Repartidor:" Foreground="{DynamicResource NavTextColor}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,6,0" FontWeight="SemiBold"/>

                    <!-- Repartidor filter combo -->
                    <ComboBox Grid.Column="3" x:Name="cmbFiltroRepartidor"
                              Background="{DynamicResource InputBgBrush}"
                              Foreground="{DynamicResource NavTextColor}"
                              BorderBrush="{DynamicResource InputBorderBrush}"
                              Height="30" FontSize="12"
                              SelectionChanged="FiltroRepartidor_Changed">
                        <ComboBoxItem Content="Todos los repartidores" Tag="-1" IsSelected="True"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- ════════ ESTADO FILTER CHIPS ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="12,6" Margin="0,0,0,10">
                <WrapPanel Orientation="Horizontal">
                    <Border x:Name="chipPedido" CornerRadius="14" Padding="16,5" Cursor="Hand"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,6,0"
                            MouseLeftButtonDown="ChipEstado_Click" Tag="Pedido">
                        <TextBlock Text="📦 Pedido" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </Border>
                    <Border x:Name="chipEnRuta" CornerRadius="14" Padding="16,5" Cursor="Hand"
                            Background="{DynamicResource GridRowHoverBrush}" Margin="0,0,6,0"
                            MouseLeftButtonDown="ChipEstado_Click" Tag="En ruta">
                        <TextBlock Text="🚚 En ruta" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                    </Border>
                    <Border x:Name="chipIncidencia" CornerRadius="14" Padding="16,5" Cursor="Hand"
                            Background="{DynamicResource GridRowHoverBrush}" Margin="0,0,6,0"
                            MouseLeftButtonDown="ChipEstado_Click" Tag="Incidencia">
                        <TextBlock Text="⚠️ Incidencia" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                    </Border>
                </WrapPanel>
            </Border>

            <!-- ════════ VENTAS GRID ════════ -->
            <Border Grid.Row="3" Background="{DynamicResource POscuro2}" CornerRadius="12" Padding="0">
                <Grid>
                    <DataGrid x:Name="dgVentas" Style="{StaticResource GridStyle}"
                              CanUserAddRows="False" IsReadOnly="True"
                              SelectionChanged="dgVentas_Seleccionado">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                            <DataGridTemplateColumn Header="Cliente" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="👤" FontSize="12" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding ClienteNombre}" FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Foreground="{DynamicResource NavTextColor}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaDisplay}" Width="85"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay, StringFormat=Bs {0}}" Width="85"/>
                            <DataGridTemplateColumn Header="Estado" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="8,2"
                                                Background="{DynamicResource AcentoBrush}" HorizontalAlignment="Left" Opacity="0.85">
                                            <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Repartidor" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🚚" FontSize="11" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding RepartidorNombre}" FontSize="12"
                                                       Foreground="{DynamicResource NavTextColor}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Delivery" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DeliveryDisplay}" FontSize="12" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border x:Name="panelEmptyState" Background="Transparent" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Name="txtEmptyState" Text="No hay ventas en este estado."
                                       Foreground="{DynamicResource SectionLabelColor}" FontSize="14"
                                       HorizontalAlignment="Center" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
