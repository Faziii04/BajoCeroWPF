<Window x:Class="ProyectoIntegradorNet10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10"
        mc:Ignorable="d"
        Title="Inicio de sesión" Height="560" Width="900" Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True">
        <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#2DAAE1" CornerRadius="16" Height="48" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2599CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E7FA8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2DAAE1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" BorderBrush="#2DAAE1" BorderThickness="1.5" CornerRadius="16" Height="40" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2DAAE1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E7FA8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" CornerRadius="30" Margin="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" Opacity="0.12" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <Border Grid.Column="0" CornerRadius="24,0,0,24" Background="Transparent">
                <Grid>
                    <!-- Imagen día (modo claro) -->
                    <Image x:Name="imgFondoDia"
                       Source="/Images/diaFondoLogin.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Left"
                       Visibility="Collapsed"/>
                    <!-- Imagen noche (modo oscuro) -->
                    <Image x:Name="imgFondoNoche"
                                              Source="/Images/nocheFondoLogin.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Left"
                       Visibility="Visible"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Rectangle Grid.Row="0" Grid.RowSpan="3" Fill="#0F5C8C" Opacity="0.3"/>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="10,50,10,10" Panel.ZIndex="1">
                            <Border Background="White" CornerRadius="50" Width="100" Height="100" HorizontalAlignment="Center">
                                <Image Source="https://images.icon-icons.com/196/PNG/128/water_23838.png" Height="90" Width="90" Margin="5"/>
                            </Border>
                            <TextBlock Text="AguaPotable Pro" FontFamily="Apple Garamond" FontSize="20" Foreground="White" Margin="10" FontWeight="Bold"/>
                            <TextBlock Text="Sistema de gestión integral" FontFamily="Apple Garamond" FontSize="14" Foreground="#C1CED4" Margin="10"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="20" Panel.ZIndex="1">
                            <Border Height="2" Margin="0,0,0,15" CornerRadius="1">
                                <Border.Background>
                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.3"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="• Control de producción" FontFamily="Apple Garamond" FontSize="14" Foreground="#C1CED4" Margin="10,8,10,0" FontWeight="Normal"/>
                            <TextBlock Text="• Gestión de recursos" FontFamily="Apple Garamond" FontSize="14" Foreground="#C1CED4" Margin="10,8,10,0" FontWeight="Normal"/>
                            <TextBlock Text="• Análisis de datos" FontFamily="Apple Garamond" FontSize="14" Foreground="#C1CED4" Margin="10,8,10,0" FontWeight="Normal"/>
                            <TextBlock Text="• Informes avanzados" FontFamily="Apple Garamond" FontSize="14" Foreground="#C1CED4" Margin="10,8,10,0" FontWeight="Normal"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>


            <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="0,24,24,0"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False">
                        <Rectangle Canvas.Right="0" Canvas.Top="0" Width="250" Height="250" Fill="#2DAAE1" Opacity="0.08" RadiusX="50" RadiusY="50"/>
                        <Polygon Canvas.Left="20" Canvas.Bottom="30" Points="0,0 30,0 15,25" Fill="#0F5C8C" Opacity="0.05"/>
                    </Canvas>

                    <!-- Window control buttons (top-right) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Panel.ZIndex="10">
                        <Border Width="34" Height="34" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnMinimize"
                            Content="─"
                            Background="Transparent"
                            Foreground="{DynamicResource LOscuro2}"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="btnMinimize_Click"
                            ToolTip="Minimize"/>
                        </Border>
                        <Border Width="34" Height="34" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnClose"
                            Content="✕"
                            Background="Transparent"
                            Foreground="{DynamicResource LOscuro2}"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="btnClose_Click"
                            ToolTip="Close"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="30,30,30,10" Panel.ZIndex="1">
                        <Border Height="4" Background="#2DAAE1" CornerRadius="8" Margin="0,0,100,20"/>
                        <TextBlock Text="Bienvenido" FontFamily="Apple Garamond" FontSize="28" Foreground="{DynamicResource LOscuro2}" FontWeight="Bold"/>
                        <TextBlock Text="Ingresa tus credenciales para continuar" FontFamily="Apple Garamond" FontSize="14" Foreground="{DynamicResource LOscuro2}" Margin="0,5,0,20"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="30" Panel.ZIndex="1">

                        <!-- Horizontal layout for Usuario & Contraseña -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Usuario" FontSize="13" Foreground="{DynamicResource LOscuro2}" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                <Border BorderBrush="#DDD" BorderThickness="1.5" CornerRadius="14" Background="{DynamicResource POscuro2}">
                                    <TextBox Name="txtUsuario"
                                     Height="44"
                                     Background="Transparent"
                                     Foreground="{DynamicResource LOscuro2}"
                                     CaretBrush="{DynamicResource LOscuro2}"
                                     BorderThickness="0"
                                     Padding="16,12"
                                     FontSize="13"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contraseña" FontSize="13" Foreground="{DynamicResource LOscuro2}" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                <Border BorderBrush="#DDD" BorderThickness="1.5" CornerRadius="14" Background="{DynamicResource POscuro2}">
                                    <PasswordBox Name="passContrasenia"
                                         Height="44"
                                         Background="Transparent"
                                         Foreground="{DynamicResource LOscuro2}"
                                         CaretBrush="{DynamicResource LOscuro2}"
                                         BorderThickness="0"
                                         Padding="16,12"
                                         FontSize="13"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,5,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Content="Recordar sesión" VerticalAlignment="Center" Foreground="{DynamicResource LOscuro2}" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="¿Olvidaste tu contraseña?" Foreground="#2DAAE1" HorizontalAlignment="Right" Cursor="Hand" FontSize="12">
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline"/>
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </Grid>


                        <!-- Buttons row side by side -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                            Name="btnInicio"
                            Content="Iniciar sesión"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="btnInicio_Click"/>

                            <Button Grid.Column="2"
                            Name="btnprueba"
                            Content="Modo prueba"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="btnprueba_Click"/>
                        </Grid>

                        <TextBlock Text="Sistema multiplataforma · Modo claro"
                           Foreground="#A0AAB5"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                        <Button Name="btnModo"
                        Content="☀ Cambiar modo"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,8,0,0"
                        Click="btnModo_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
