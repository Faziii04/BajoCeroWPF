<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWProduccion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="PWProduccion" Height="650" Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="🏭" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nueva Producción"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Registrar proceso productivo"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ FORM ════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- HEADER FIELDS -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Datos de la Producción" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fecha Inicio *" Foreground="{DynamicResource NavTextColor}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="dpFechaInicio" Height="36" FontSize="13"
                                                Background="{DynamicResource InputBgBrush}"
                                                Foreground="{DynamicResource NavTextColor}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                BorderThickness="1" Margin="0,0,0,10"
                                                DisplayDateStart="{x:Static sys:DateTime.Today}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Costo Total" Foreground="{DynamicResource NavTextColor}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox x:Name="txtCostoTotal"
                                             Background="{DynamicResource InputBgBrush}"
                                             Foreground="{DynamicResource NavTextColor}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="10,7" FontSize="13"
                                             Margin="0,0,0,10"
                                             CaretBrush="{DynamicResource NavTextColor}"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Estado" Foreground="{DynamicResource NavTextColor}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbEstado" Height="36" FontSize="13"
                                              Background="{DynamicResource InputBgBrush}"
                                              Foreground="{DynamicResource NavTextColor}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              BorderThickness="1" Margin="0,0,0,10"
                                              SelectionChanged="CmbEstado_SelectionChanged"
                                              IsEnabled="False">
                                        <ComboBoxItem Content="Planificado" IsSelected="True"/>
                                        <ComboBoxItem Content="En proceso"/>
                                        <ComboBoxItem Content="Completado"/>
                                        <ComboBoxItem Content="Cancelado"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2" x:Name="panelDeposito" Visibility="Collapsed">
                                    <TextBlock Text="Depósito Destino *" Foreground="{DynamicResource NavTextColor}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbDeposito" Height="36" FontSize="13"
                                              DisplayMemberPath="Nombre" SelectedValuePath="Id"
                                              Background="{DynamicResource InputBgBrush}"
                                              Foreground="{DynamicResource NavTextColor}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              BorderThickness="1" Margin="0,0,0,10"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- INSUMOS SECTION -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="20" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Insumos Consumidos" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,4"/>
                            <TextBlock Text="Se descontarán del stock al iniciar la producción"
                                       FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" x:Name="cmbInsumo" Height="34" FontSize="12"
                                          DisplayMemberPath="Nombre" SelectedValuePath="Id"
                                          Background="{DynamicResource InputBgBrush}"
                                          Foreground="{DynamicResource NavTextColor}"
                                          BorderBrush="{DynamicResource InputBorderBrush}"
                                          BorderThickness="1" Margin="0,0,6,0"/>

                                <TextBox Grid.Column="1" x:Name="txtCantidadInsumo" Height="34" FontSize="12"
                                         Text="1"
                                         Background="{DynamicResource InputBgBrush}"
                                         Foreground="{DynamicResource NavTextColor}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1" Padding="6,0" Margin="0,0,6,0"
                                         CaretBrush="{DynamicResource NavTextColor}"
                                         VerticalContentAlignment="Center"/>

                                <Button Grid.Column="2" x:Name="btnAgregarInsumo" Height="34"
                                        Style="{StaticResource OutlineButton}" Click="BtnAgregarInsumo_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" Margin="0,0,4,0"/>
                                        <TextBlock Text="Agregar"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Insumos list -->
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="8"
                                    Margin="0,8,0,0" MinHeight="60" MaxHeight="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="lstInsumos">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="6,4" Margin="0,0,0,2"
                                                        Background="{DynamicResource FOscuro1}" CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding InsumoNombre}"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CantidadDisplay}"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding UnidadMedida}"
                                                                   Foreground="{DynamicResource SectionLabelColor}"
                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding SubtotalDisplay, StringFormat=Bs {0}}"
                                                                   Foreground="{DynamicResource AcentoBrush}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="4" Text="✕" FontSize="12" Cursor="Hand"
                                                                   Foreground="#E74C3C"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   MouseLeftButtonDown="RemoveInsumo_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- PRODUCTOS SECTION -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="20" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Productos Fabricados" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,4"/>
                            <TextBlock Text="Se añadirán al inventario al completar la producción"
                                       FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" x:Name="cmbProducto" Height="34" FontSize="12"
                                          DisplayMemberPath="Nombre" SelectedValuePath="Id"
                                          Background="{DynamicResource InputBgBrush}"
                                          Foreground="{DynamicResource NavTextColor}"
                                          BorderBrush="{DynamicResource InputBorderBrush}"
                                          BorderThickness="1" Margin="0,0,6,0"/>

                                <TextBox Grid.Column="1" x:Name="txtCantidadProducto" Height="34" FontSize="12"
                                         Text="1"
                                         Background="{DynamicResource InputBgBrush}"
                                         Foreground="{DynamicResource NavTextColor}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1" Padding="6,0" Margin="0,0,6,0"
                                         CaretBrush="{DynamicResource NavTextColor}"
                                         VerticalContentAlignment="Center"/>

                                <Button Grid.Column="2" x:Name="btnAgregarProducto" Height="34"
                                        Style="{StaticResource OutlineButton}" Click="BtnAgregarProducto_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" Margin="0,0,4,0"/>
                                        <TextBlock Text="Agregar"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Productos list -->
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="8"
                                    Margin="0,8,0,0" MinHeight="60" MaxHeight="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="lstProductos">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="6,4" Margin="0,0,0,2"
                                                        Background="{DynamicResource FOscuro1}" CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ProductoNombre}"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding CantidadDisplay}"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding PrecioVentaDisplay, StringFormat=Bs {0}}"
                                                                   Foreground="{DynamicResource SectionLabelColor}"
                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="✕" FontSize="12" Cursor="Hand"
                                                                   Foreground="#E74C3C"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   MouseLeftButtonDown="RemoveProducto_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ════════ FOOTER ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12"
                    Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,6,0"/>
                            <TextBlock Text="Guardar"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" Margin="0,0,6,0"/>
                            <TextBlock Text="Eliminar"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click">
                        <TextBlock Text="Cancelar"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
