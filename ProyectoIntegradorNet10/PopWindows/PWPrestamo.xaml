<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWPrestamo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        xmlns:models="clr-namespace:ProyectoIntegradorNet10.Models"
        mc:Ignorable="d"
        Title="PWPrestamo" Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="20"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="💳" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nuevo Préstamo"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Gestión de préstamos de productos a clientes"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ LEFT: PRODUCT GALLERY ═══ -->
                <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Product search -->
                        <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                Padding="8,0" Height="34" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtBuscarProducto"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="13" VerticalAlignment="Center"
                                         TextChanged="TxtBuscarProducto_TextChanged"
                                         Style="{x:Null}"/>
                                <TextBlock IsHitTestVisible="False" Margin="8,0"
                                           Text="Buscar producto..." Foreground="{DynamicResource SectionLabelColor}" FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscarProducto}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform"
                                      Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent"
                                      Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                            </Grid>
                        </Border>

                        <!-- Family search -->
                        <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                Padding="10,0" Margin="0,0,0,4" Height="28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtBuscarFamilia"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="11" VerticalAlignment="Center"
                                         TextChanged="TxtBuscarFamilia_TextChanged"
                                         Style="{x:Null}"/>
                                <Path Grid.Column="1" Width="16" Height="16" Margin="4,0" Stretch="Uniform"
                                      Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5" Fill="Transparent"
                                      Data="M11,11 L16,16 M7,12 C4,12 2,10 2,7 C2,4 4,2 7,2 C10,2 12,4 12,7 C12,10 10,12 7,12 Z"/>
                            </Grid>
                        </Border>

                        <!-- Family filter chips -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Auto" Margin="0,0,0,6">
                            <WrapPanel x:Name="pnlFiltroFamilias" Orientation="Horizontal">
                                <Border x:Name="chipTodas" CornerRadius="12" Padding="10,3" Cursor="Hand"
                                        Background="{DynamicResource AcentoBrush}" Margin="0,0,4,3"
                                        MouseLeftButtonDown="ChipFamilia_Click" Tag="-1">
                                    <TextBlock Text="Todas" FontSize="11" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>

                        <!-- Product cards -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="icProductos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:ProductoModel}">
                                        <Border Width="150" Margin="0,0,8,8"
                                                Background="{DynamicResource POscuro2}"
                                                CornerRadius="10"
                                                BorderBrush="{DynamicResource SeparatorColor}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ProductCard_Click">
                                            <StackPanel>
                                                <Border Width="150" Height="150"
                                                        Background="{DynamicResource FOscuro1}"
                                                        CornerRadius="10,10,0,0"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding Url}"
                                                               Stretch="UniformToFill"
                                                               Width="150" Height="150"/>
                                                        <TextBlock Text="📦" FontSize="28"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Url}" Value="">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Margin="8,6,8,8">
                                                    <TextBlock Text="{Binding Nombre}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource NavTextColor}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding PrecioDisplay, StringFormat='Bs {0}'}"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="{DynamicResource NavTextColor}"/>
                                                    <TextBlock Text="{Binding StockDisplay, StringFormat='Stock: {0}'}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource SectionLabelColor}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ═══ Separator ═══ -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

                <!-- ═══ RIGHT: LOAN FORM ═══ -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Datos del Préstamo" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>

                            <!-- Cliente (searchable by CI + name) -->
                            <TextBlock Text="Cliente *" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <ComboBox x:Name="cmbCliente"
                                      Style="{StaticResource FormComboBox}"
                                      SelectedValuePath="Ci"
                                      TextSearch.TextPath="NombreCompleto"
                                      IsEditable="True" StaysOpenOnEdit="True"
                                      IsTextSearchEnabled="False"
                                      SelectionChanged="CmbCliente_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Ci}"
                                                       FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding NombreCompleto}"
                                                       FontSize="13" Foreground="{DynamicResource NavTextColor}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Estado -->
                            <TextBlock Text="Estado" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <ComboBox x:Name="cmbEstado" Margin="0,0,0,10">
                                <ComboBoxItem Content="Activo" IsSelected="True"/>
                                <ComboBoxItem Content="Completado"/>
                                <ComboBoxItem Content="Cancelado"/>
                            </ComboBox>

                            <TextBlock x:Name="txtFechaInfo" Text="" FontSize="12"
                                       Foreground="{DynamicResource SectionLabelColor}" Margin="0,0,0,8"/>

                            <!-- ═══ Selected product + quantity ═══ -->
                            <Border x:Name="panelCantidad" Background="{DynamicResource POscuro2}"
                                    CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="txtSelectedProductName" Text=""
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource NavTextColor}"/>
                                        <TextBlock x:Name="txtSelectedProductPrice" Text=""
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SectionLabelColor}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Width="28" Height="28" Padding="0"
                                                Background="{DynamicResource SeparatorColor}"
                                                Foreground="{DynamicResource NavTextColor}"
                                                BorderThickness="0" FontSize="14" FontWeight="Bold"
                                                Cursor="Hand" Margin="0,0,4,0"
                                                Click="BtnCantidadMenos_Click">
                                            <TextBlock Text="−" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <TextBox x:Name="txtCantidad" Text="1"
                                                 Width="40" Height="28" Padding="2"
                                                 Background="{DynamicResource InputBgBrush}"
                                                 Foreground="{DynamicResource NavTextColor}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1"
                                                 FontSize="13" FontWeight="Bold"
                                                 HorizontalAlignment="Center"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Width="28" Height="28" Padding="0"
                                                Background="{DynamicResource SeparatorColor}"
                                                Foreground="{DynamicResource NavTextColor}"
                                                BorderThickness="0" FontSize="14" FontWeight="Bold"
                                                Cursor="Hand" Margin="4,0,0,0"
                                                Click="BtnCantidadMas_Click">
                                            <TextBlock Text="+" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Add button -->
                            <Button x:Name="btnAgregarProducto" Style="{StaticResource ActionButton}"
                                    Click="BtnAgregarProducto_Click"
                                    Visibility="Collapsed" Margin="0,0,0,10"
                                    HorizontalAlignment="Stretch" Height="36">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="＋" Margin="0,0,6,0"/>
                                    <TextBlock Text="Agregar al préstamo"/>
                                </StackPanel>
                            </Button>

                            <!-- ═══ Added products list ═══ -->
                            <TextBlock Text="Productos en el préstamo" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,8,0,8"/>

                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="0"
                                    MaxHeight="200" Margin="0,0,0,10">
                                <ListBox x:Name="lstProductos" Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,4" Margin="0,1"
                                                    Background="{DynamicResource FOscuro1}"
                                                    CornerRadius="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="24"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding ProductoNombre}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource NavTextColor}"/>
                                                        <TextBlock Text="{Binding ProductoPrecio, StringFormat='Bs {0:N2} c/u'}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource SectionLabelColor}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Cant:" FontSize="9"
                                                                   Foreground="{DynamicResource SectionLabelColor}"/>
                                                        <TextBlock Text="{Binding Cantidad}"
                                                                   FontSize="12" FontWeight="Bold"
                                                                   Foreground="{DynamicResource NavTextColor}"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ValorReposicion, StringFormat=Bs {0:N2}}"
                                                               FontSize="12" FontWeight="Bold"
                                                               Foreground="{DynamicResource NavTextColor}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Grid.Column="3" Text="✕"
                                                               Foreground="#E74C3C" FontSize="13"
                                                               Cursor="Hand" VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               MouseDown="RemoveProducto_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- ═══ Total ═══ -->
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,10"
                                    Margin="0,4,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Total" FontSize="13"
                                                   Foreground="{DynamicResource SectionLabelColor}"/>
                                        <TextBlock x:Name="txtItemsCount" Text="0 productos"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SectionLabelColor}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" x:Name="txtTotal" Text="Bs 0.00"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- ═══ Footer actions ═══ -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click"
                                        HorizontalAlignment="Stretch" Height="40" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                                        <TextBlock Text="Guardar"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click"
                                        IsEnabled="False" Height="40" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                        <TextBlock Text="Eliminar"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click" Height="40">
                                    <TextBlock Text="Cancelar"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
