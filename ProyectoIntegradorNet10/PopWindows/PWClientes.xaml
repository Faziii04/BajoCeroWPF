<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWClientes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        mc:Ignorable="d"
        Title="Cliente" Height="740" Width="960"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>
        <!-- ─── TextBox style for form ─── -->
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Coord TextBox (read-only) ─── -->
        <Style TargetType="TextBox" x:Key="CoordTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ─── Form label style ─── -->
        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- ─── Action buttons ─── -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="👤" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nuevo Cliente"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Complete los datos del cliente"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Close button -->
                <Border Grid.Column="1" x:Name="closeButton" Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ CONTENT: FORM + MAP SIDE BY SIDE ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: FORM ─── -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- ─── Image Section ─── -->
                        <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16"
                                Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Image preview -->
                                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="10"
                                        Background="{DynamicResource POscuro2}"
                                        BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1"
                                        Margin="0,0,12,0">
                                    <Grid>
                                        <Image x:Name="imgPreview" Width="60" Height="60"
                                               Stretch="UniformToFill" Visibility="Collapsed"
                                               ClipToBounds="True"/>
                                        <Border CornerRadius="10" ClipToBounds="True">
                                            <Image x:Name="imgPreviewClip" Width="60" Height="60"
                                                   Stretch="UniformToFill" Visibility="Collapsed"/>
                                        </Border>
                                        <TextBlock x:Name="txtNoImage" Text="📷"
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Foto del cliente"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock x:Name="txtImageStatus" Text="Sin imagen"
                                               FontSize="10" Foreground="{DynamicResource SectionLabelColor}"
                                               Margin="0,2,0,4"/>
                                    <TextBox x:Name="txtUrl" Style="{StaticResource FormTextBox}"
                                             TextChanged="TxtUrl_TextChanged"
                                             Height="28" FontSize="11" Padding="6,4"
                                             Margin="0,0,0,4"/>
                                    <Button Style="{StaticResource ActionButton}"
                                            Click="BtnUploadImage_Click" Height="28"
                                            Padding="10,4" Margin="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📂" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="Seleccionar" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ─── Personal Data Section ─── -->
                        <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Datos personales" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,12"/>

                                <TextBlock Text="CI *" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtCi" Style="{StaticResource FormTextBox}"/>

                                <TextBlock Text="Nombre *" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtNombre" Style="{StaticResource FormTextBox}"/>

                                <TextBlock Text="Apellido" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtApellido" Style="{StaticResource FormTextBox}"/>

                                <TextBlock Text="Teléfono" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtTelefono" Style="{StaticResource FormTextBox}"/>

                                <TextBlock Text="Dirección" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtDireccion" Style="{StaticResource FormTextBox}"
                                         TextWrapping="Wrap" AcceptsReturn="False" MaxHeight="50"/>

                                <TextBlock Text="NIT" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="txtNit" Style="{StaticResource FormTextBox}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── Separator ─── -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorColor}" Opacity="0.3" RadiusX="1"/>

                <!-- ─── RIGHT: MAP ─── -->
                <Border Grid.Column="2" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Map container with floating search overlay -->
                        <Grid Grid.Row="0">
                            <!-- Map fills the entire space -->
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8"
                                    BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Search bar floats at top -->
                                    <Border Grid.Row="0" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                            Padding="8" Margin="8,8,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtBuscarDireccion"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource NavTextColor}"
                                                     FontSize="12" VerticalAlignment="Center"
                                                     Padding="4,0"
                                                     Text="Buscar dirección..."
                                                     GotFocus="TxtBuscarDireccion_GotFocus"
                                                     LostFocus="TxtBuscarDireccion_LostFocus"/>
                                            <Button Grid.Column="1" x:Name="btnBuscar" Style="{StaticResource ActionButton}"
                                                    Click="BtnBuscarDireccion_Click"
                                                    Height="30" Width="70" Padding="0" Margin="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔍" FontSize="12" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Buscar" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <!-- GMap fills remaining space -->
                                    <gmap:GMapControl Grid.Row="1" x:Name="gmapControl" />
                                </Grid>
                            </Border>

                            <!-- Search results overlay (appears when visible) -->
                            <Border x:Name="resultadosPanel" Visibility="Collapsed"
                                    Background="{DynamicResource POscuro2}" CornerRadius="8"
                                    BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1"
                                    MaxHeight="150" Margin="8,52,8,0"
                                    VerticalAlignment="Top">
                                <ListBox x:Name="lstResultados" Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         FontSize="11"
                                         SelectionChanged="LstResultados_SelectionChanged"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding display_name}" TextWrapping="Wrap"
                                                       Margin="6,4" Foreground="{DynamicResource NavTextColor}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Map header + toggle overlay (bottom-left) -->
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                        Margin="12,0,0,10" IsHitTestVisible="False">
                                <TextBlock Text="Ubicación en el mapa" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White" Opacity="0.8">
                                    <TextBlock.Effect>
                                        <DropShadowEffect ShadowDepth="1" Opacity="0.6" BlurRadius="3"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>

                        </Grid>

                        <!-- Row 1: Coordinates display + toggle -->
                        <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                Padding="10,8" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Lat:" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SectionLabelColor}"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1" x:Name="txtLatitud" Style="{StaticResource CoordTextBox}"/>

                                <TextBlock Grid.Column="2" Text="Lng:" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SectionLabelColor}"
                                           VerticalAlignment="Center" Margin="10,0,4,0"/>
                                <TextBox Grid.Column="3" x:Name="txtLongitud" Style="{StaticResource CoordTextBox}"/>

                                <!-- Spacer -->
                                <TextBlock Grid.Column="4" Text=""/>

                                <!-- Toggle -->
                                <CheckBox Grid.Column="5" x:Name="chkPermitirEdicion" IsChecked="True"
                                          Checked="ChkPermitirEdicion_Checked"
                                          Unchecked="ChkPermitirEdicion_Checked"
                                          Foreground="{DynamicResource NavTextColor}"
                                          FontSize="11" FontWeight="SemiBold"
                                          VerticalAlignment="Center" Cursor="Hand">
                                    <TextBlock Text="📍 Editar ubicación" FontSize="11"/>
                                </CheckBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════ FOOTER / BUTTONS ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12"
                    Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,6,0"/>
                            <TextBlock Text="Guardar"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" Margin="0,0,6,0"/>
                            <TextBlock Text="Eliminar"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnCancelar" Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click">
                        <TextBlock Text="Cancelar"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
