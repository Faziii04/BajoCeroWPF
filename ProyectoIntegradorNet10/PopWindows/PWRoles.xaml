<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWRoles"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="Roles" Height="640" Width="850"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox toggle style for permission cards -->
        <Style TargetType="CheckBox" x:Key="ToggleCardStyle">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="ToggleBg"
                                Width="42" Height="24"
                                CornerRadius="12"
                                Background="{DynamicResource SeparatorColor}"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Border x:Name="ToggleKnob"
                                    Width="18" Height="18"
                                    CornerRadius="9"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBg" Property="Background" Value="{DynamicResource AcentoBrush}"/>
                                <Setter TargetName="ToggleKnob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="ToggleKnob" Property="Margin" Value="0,0,3,0"/>
                                <Setter TargetName="ToggleKnob" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleKnob" Property="Width" Value="20"/>
                                <Setter TargetName="ToggleKnob" Property="Height" Value="20"/>
                                <Setter TargetName="ToggleKnob" Property="CornerRadius" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="28,24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,14,0">
                        <TextBlock Text="👥" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nuevo Rol"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Defina el nombre, descripción y permisos del rol"
                                   FontSize="12" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="34" Height="34" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click" VerticalAlignment="Top">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ BODY: SPLIT LAYOUT ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: ROLE INFO ─── -->
                <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="18,20"
                        VerticalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{DynamicResource AcentoBrush}" Margin="0,0,10,0">
                                <TextBlock Text="📋" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Datos del Rol" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                                <TextBlock Text="Información básica" FontSize="10"
                                           Foreground="{DynamicResource SectionLabelColor}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Nombre *" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtNombre" Style="{StaticResource FormTextBox}"
                                 ToolTip="Nombre del rol (requerido)"/>

                        <TextBlock Text="Descripción" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtDescripcion" Style="{StaticResource FormTextBox}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                                 VerticalContentAlignment="Top" Padding="10,7"
                                 ToolTip="Descripción opcional del rol"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <GridSplitter Grid.Column="1" Width="12" Background="Transparent"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              IsEnabled="False"/>

                <!-- ─── RIGHT: PERMISSIONS ─── -->
                <Border Grid.Column="2" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="18,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Permission header with count -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="{DynamicResource AcentoBrush}" Margin="0,0,10,0">
                                <TextBlock Text="🔑" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Permisos" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock x:Name="txtPermisosCount" Text="0 seleccionados"
                                               FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                                    <TextBlock Text=" de " FontSize="11"
                                               Foreground="{DynamicResource SectionLabelColor}"/>
                                    <TextBlock x:Name="txtPermisosTotal" Text="0"
                                               FontSize="11" Foreground="{DynamicResource SectionLabelColor}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="btnSelectAll"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" FontSize="11" Padding="10,0" Margin="0,0,5,0"
                                        Click="BtnSelectAll_Click">
                                    <TextBlock Text="✓ Todos"/>
                                </Button>
                                <Button x:Name="btnDeselectAll"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="28" FontSize="11" Padding="10,0"
                                        Click="BtnDeselectAll_Click">
                                    <TextBlock Text="✕ Ninguno"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Search -->
                        <Border Grid.Row="1" Background="{DynamicResource POscuro2}" CornerRadius="8"
                                Padding="10,0" Height="32" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtBuscarPermiso" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}"
                                         CaretBrush="{DynamicResource NavTextColor}"
                                         FontSize="12" VerticalAlignment="Center"
                                         TextChanged="TxtBuscarPermiso_TextChanged"/>
                                <TextBlock IsHitTestVisible="False" Margin="10,0"
                                           Text="Filtrar permisos..."
                                           Foreground="{DynamicResource SectionLabelColor}"
                                           FontSize="12" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBuscarPermiso}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="🔍" FontSize="12"
                                           VerticalAlignment="Center" Margin="6,0"/>
                            </Grid>
                        </Border>

                        <!-- Permission card grid -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="lstPermisos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="CardBorder"
                                                Width="180" MinHeight="78"
                                                Margin="0,0,8,8"
                                                Background="{DynamicResource POscuro2}"
                                                CornerRadius="10"
                                                BorderBrush="{DynamicResource SeparatorColor}"
                                                BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="PermisoCard_Click">
                                            <Grid Margin="10,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon + name -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal"
                                                            Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding PermisoIcono}" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding PermisoNombre}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource NavTextColor}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Toggle switch -->
                                                <CheckBox Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                                          Style="{StaticResource ToggleCardStyle}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Checked="Permiso_Changed"
                                                          Unchecked="Permiso_Changed"/>

                                                <!-- Description -->
                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="{Binding PermisoDescripcion}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SectionLabelColor}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="30"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush"
                                                        Value="{DynamicResource AcentoBrush}"/>
                                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════ FOOTER ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12"
                    Padding="16,14" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status text -->
                    <TextBlock x:Name="txtStatus" Grid.Column="0"
                               Text="Complete los campos requeridos para guardar."
                               FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click"
                                Height="38" Padding="18,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" Margin="0,0,8,0" FontSize="15"/>
                                <TextBlock Text="Guardar Rol" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click"
                                Height="38" Padding="18,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗑" Margin="0,0,8,0" FontSize="15"/>
                                <TextBlock Text="Eliminar" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click"
                                Height="38" Padding="18,0">
                            <TextBlock Text="Cancelar" FontSize="13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
