<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWOrdenesCompra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="PWOrdenesCompra" Height="720" Width="740"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="ScrollBar"><Setter Property="Width" Value="8"/><Setter Property="Background" Value="Transparent"/></Style>
        <Style TargetType="Thumb"><Setter Property="Background" Value="{DynamicResource SeparatorColor}"/><Setter Property="BorderThickness" Value="0"/></Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nueva Orden de Compra" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Gestión de órdenes de compra a proveedores" FontSize="11" Foreground="{DynamicResource SectionLabelColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource FOscuro1}" Cursor="Hand" MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- HEADER -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Datos de la Orden" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Proveedor *" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbProveedor" Style="{StaticResource FormComboBox}" SelectedValuePath="Id"
                                              IsEditable="True" StaysOpenOnEdit="True"
                                              TextSearch.TextPath="Nombre"
                                              SelectionChanged="CmbProveedor_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Nombre}" FontSize="13" Foreground="{DynamicResource NavTextColor}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Estado" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="cmbEstado" Width="140" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Pedido" IsSelected="True"/>
                                        <ComboBoxItem Content="Recibido"/>
                                        <ComboBoxItem Content="Cancelado"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Fecha/Hora Pedido with Hoy button -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fecha Pedido *" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="dpFechaPedido"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hora Pedido *" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox x:Name="txtHoraPedido" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="3" Content="📅 Ahora" FontSize="11" Height="34" Padding="10,0" Margin="8,18,0,0"
                                        Background="{DynamicResource SeparatorColor}" Foreground="{DynamicResource NavTextColor}"
                                        BorderThickness="0" Cursor="Hand" Click="BtnAhoraPedido_Click" VerticalAlignment="Bottom"/>
                            </Grid>

                            <!-- Fecha/Hora Llegada with Hoy button -->
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fecha Llegada" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <DatePicker x:Name="dpFechaLlegada"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hora Llegada" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                    <TextBox x:Name="txtHoraLlegada" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="3" Content="📅 Ahora" FontSize="11" Height="34" Padding="10,0" Margin="8,18,0,0"
                                        Background="{DynamicResource SeparatorColor}" Foreground="{DynamicResource NavTextColor}"
                                        BorderThickness="0" Cursor="Hand" Click="BtnAhoraLlegada_Click" VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- INSUMOS -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Insumos" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,12"/>
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="12,10" Margin="0,0,0,10" BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="cmbInsumoAdd" SelectedValuePath="Id" Style="{StaticResource FormComboBox}" Margin="0" Height="34"
                                              IsEditable="True" StaysOpenOnEdit="True" TextSearch.TextPath="Nombre">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Nombre}" FontSize="13" Foreground="{DynamicResource NavTextColor}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding PrecioDisplay, StringFormat='Bs {0}'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AcentoBrush}" Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Border Grid.Column="1" Background="{DynamicResource FOscuro1}" CornerRadius="8" Padding="0" Height="34" Margin="8,0,0,0" Width="80">
                                        <TextBox x:Name="txtCantidadAdd" Text="1" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource NavTextColor}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    </Border>
                                    <Button Grid.Column="2" Style="{StaticResource ActionButton}" Click="BtnAddInsumo_Click" Height="34" Padding="14,0" Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="＋" FontSize="14" FontWeight="Bold" Margin="0,0,6,0"/><TextBlock Text="Agregar" FontSize="12" FontWeight="SemiBold"/></StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="txtNoInsumos" Text="No hay insumos agregados." FontSize="12" Foreground="{DynamicResource SectionLabelColor}" Visibility="Visible" Margin="0,0,0,6"/>
                            <ListBox x:Name="lstInsumos" Background="Transparent" BorderThickness="0" MaxHeight="200" Margin="0,0,0,8"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" Margin="0,1" Background="{DynamicResource FOscuro1}" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/><ColumnDefinition Width="80"/><ColumnDefinition Width="24"/></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding InsumoNombre}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Cantidad, StringFormat='×{0}'}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding SubtotalDisplay, StringFormat=Bs {0}}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AcentoBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="3" Text="✕" Foreground="#E74C3C" FontSize="13" Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Center" MouseDown="RemoveInsumo_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Total Monto:" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" x:Name="txtTotal" Text="Bs 0.00" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AcentoBrush}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="💾" Margin="0,0,6,0"/><TextBlock Text="Guardar"/></StackPanel>
                    </Button>
                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="🗑" Margin="0,0,6,0"/><TextBlock Text="Eliminar"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click"><TextBlock Text="Cancelar"/></Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
