<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWInsumos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="PWInsumos" Height="600" Width="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="ScrollBar"><Setter Property="Width" Value="8"/><Setter Property="Background" Value="Transparent"/></Style>
        <Style TargetType="Thumb"><Setter Property="Background" Value="{DynamicResource SeparatorColor}"/><Setter Property="BorderThickness" Value="0"/></Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nuevo Insumo" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Complete los datos del insumo" FontSize="11" Foreground="{DynamicResource SectionLabelColor}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="{DynamicResource FOscuro1}" Cursor="Hand" MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource NavTextColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Datos del Insumo" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,16"/>
                        <TextBlock Text="Nombre *" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtNombre" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" Margin="0,0,0,12" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                        <TextBlock Text="Descripción" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtDescripcion" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" Margin="0,0,0,12" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center" TextWrapping="Wrap" AcceptsReturn="False" MaxHeight="60"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Unidad de Medida" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <TextBox x:Name="txtUnidadMedida" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" Margin="0,0,0,0" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Precio Unitario" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <TextBox x:Name="txtPrecioUnitario" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" Margin="0,0,0,0" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Cantidad en Stock" Foreground="{DynamicResource NavTextColor}" FontSize="12" FontWeight="SemiBold" Margin="0,12,0,3"/>
                        <TextBox x:Name="txtCantidadStock" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource NavTextColor}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,7" FontSize="13" Margin="0,0,0,0" CaretBrush="{DynamicResource NavTextColor}" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="💾" Margin="0,0,6,0"/><TextBlock Text="Guardar"/></StackPanel>
                    </Button>
                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="🗑" Margin="0,0,6,0"/><TextBlock Text="Eliminar"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click"><TextBlock Text="Cancelar"/></Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
