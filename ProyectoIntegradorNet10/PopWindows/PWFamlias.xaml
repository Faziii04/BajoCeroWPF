<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWFamlias"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="Familia de Producto" Height="620" Width="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ─── TextBox style for form ─── -->
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Form label style ─── -->
        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- ─── Action buttons ─── -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── Product card template with image + remove ─── -->
        <DataTemplate x:Key="ProductItemTemplate">
            <Border Background="{DynamicResource POscuro2}" CornerRadius="10" Padding="8"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Image / icon -->
                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="8"
                            Background="{DynamicResource FOscuro1}" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Url}"
                                   Stretch="UniformToFill"
                                   Width="50" Height="50"/>
                            <TextBlock Text="📦" FontSize="20"
                                       Foreground="{DynamicResource NavTextColor}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Url}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Url}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                        <TextBlock Text="{Binding Nombre}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding PrecioVenta, StringFormat={}Bs {0:N2}}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Estado}"
                                       FontSize="10"
                                       Foreground="{DynamicResource SectionLabelColor}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Remove button -->
                    <Border Grid.Column="2" Width="32" Height="32" CornerRadius="8"
                            Background="{DynamicResource FOscuro1}" Cursor="Hand"
                            MouseLeftButtonDown="BtnRemoveProducto_Click"
                            ToolTip="Quitar producto de esta familia">
                        <TextBlock Text="✕" FontSize="12" FontWeight="Bold"
                                   Foreground="#E74C3C"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="📁" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Nueva Familia"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Complete los datos de la familia"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Close button -->
                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ FORM SCROLLVIEWER ════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- ─── Family Data Section ─── -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Datos de la familia" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}" Margin="0,0,0,12"/>

                            <TextBlock Text="Nombre *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtNombre" Style="{StaticResource FormTextBox}"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False"/>

                            <TextBlock Text="Descripción" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtDescripcion" Style="{StaticResource FormTextBox}"
                                     MinHeight="70" MaxHeight="120"/>

                            <TextBlock Text="URL de imagen" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtUrl" Style="{StaticResource FormTextBox}"
                                     VerticalContentAlignment="Center"
                                     AcceptsReturn="False"
                                     TextChanged="TxtUrl_TextChanged"/>

                            <!-- Image preview -->
                            <Border Width="100" Height="100" CornerRadius="10"
                                    Background="{DynamicResource POscuro2}"
                                    BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0">
                                <Grid>
                                    <Image x:Name="imgPreview" Width="100" Height="100"
                                           Stretch="UniformToFill" Visibility="Collapsed"
                                           ClipToBounds="True"/>
                                    <TextBlock x:Name="txtNoImage" Text="📷"
                                               FontSize="34"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ─── Linked Products Section ─── -->
                    <Border x:Name="borderProductos" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16"
                            Margin="0,0,0,12" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Productos vinculados" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource NavTextColor}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtProductoCount" Grid.Column="1"
                                           FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl x:Name="icProductosVinculados"
                                          ItemTemplate="{StaticResource ProductItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock x:Name="txtNoProductos" Text="No hay productos vinculados a esta familia."
                                       FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                       Visibility="Collapsed" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ════════ FOOTER / BUTTONS ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12"
                    Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}" Click="BtnGuardar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,6,0"/>
                            <TextBlock Text="Guardar"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}" Click="BtnEliminar_Click" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" Margin="0,0,6,0"/>
                            <TextBlock Text="Eliminar"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="BtnCancelar_Click">
                        <TextBlock Text="Cancelar"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
