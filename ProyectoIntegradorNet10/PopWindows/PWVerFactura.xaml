<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWVerFactura"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="Ver Factura" Height="580" Width="720"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="📄" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Detalle de Factura"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock x:Name="txtSubtitulo" Text="Información completa de la factura"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource FOscuro1}" Cursor="Hand"
                        MouseDown="BtnCerrar_Click" VerticalAlignment="Center">
                    <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource NavTextColor}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- ════════ CONTENT ════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Factura header info -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       x:Name="txtFacturaId" Text="Factura #---"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AcentoBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="txtFacturaFecha" Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       x:Name="txtVentaId" Text="Venta #---"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,6,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       x:Name="txtCliente" Text=""
                                       FontSize="13"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,2,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                       x:Name="txtNit" Text=""
                                       FontSize="12"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       Margin="0,2,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Montos -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Subtotal:"
                                       FontSize="13"
                                       Foreground="{DynamicResource NavTextColor}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="txtSubtotal" Text="Bs 0.00"
                                       FontSize="13"
                                       Foreground="{DynamicResource NavTextColor}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Descuento:"
                                       FontSize="13"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       x:Name="txtDescuento" Text="Bs 0.00"
                                       FontSize="13"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,4,0,0"/>

                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Background="{DynamicResource POscuro2}" CornerRadius="8"
                                    Padding="12,8" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Total:" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               x:Name="txtTotal" Text="Bs 0.00"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource AcentoBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Productos -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="📦" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Productos" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                            </StackPanel>
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="8"
                                    MaxHeight="160">
                                <ListBox x:Name="lstProductos" Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Margin="0,2"
                                                       Foreground="{DynamicResource NavTextColor}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Pagos -->
                    <Border Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="💳" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Pagos" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource NavTextColor}"/>
                            </StackPanel>
                            <Border Background="{DynamicResource POscuro2}" CornerRadius="8" Padding="8"
                                    MaxHeight="160">
                                <ListBox x:Name="lstPagos" Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource NavTextColor}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" Margin="0,2"
                                                       Foreground="{DynamicResource NavTextColor}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ════════ FOOTER ════════ -->
            <Border Grid.Row="2" Background="{DynamicResource FOscuro1}" CornerRadius="12"
                    Padding="16,12" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ActionButton}" Click="BtnCerrar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" Margin="0,0,8,0"/>
                            <TextBlock Text="Cerrar"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
