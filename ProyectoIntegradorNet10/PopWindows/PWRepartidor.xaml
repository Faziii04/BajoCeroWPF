<Window x:Class="ProyectoIntegradorNet10.PopWindows.PWRepartidor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.PopWindows"
        mc:Ignorable="d"
        Title="Repartidores" Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ─── TextBox style ─── -->
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── ComboBox style ─── -->
        <Style TargetType="ComboBox" x:Key="FormComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── Form label ─── -->
        <Style TargetType="TextBlock" x:Key="FormLabel">
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- ─── Action button ─── -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A93226"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="{DynamicResource SeparatorColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource POscuro2}" CornerRadius="16" Padding="24"
            BorderBrush="{DynamicResource SeparatorColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════ HEADER ════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{DynamicResource AcentoBrush}" Margin="0,0,12,0">
                        <TextBlock Text="🚚" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtTitulo" Text="Gestión de Repartidores"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"/>
                        <TextBlock Text="Administre los repartidores y sus asignaciones"
                                   FontSize="11" Foreground="{DynamicResource SectionLabelColor}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnNuevo" Style="{StaticResource ActionButton}" Click="BtnNuevo_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo Repartidor"/>
                        </StackPanel>
                    </Button>
                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="8"
                            Background="{DynamicResource FOscuro1}" Cursor="Hand"
                            MouseDown="BtnCerrar_Click" VerticalAlignment="Center">
                        <TextBlock Text="✕" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource NavTextColor}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ════════ MAIN CONTENT ════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: List of repartidores ─── -->
                <Border Grid.Column="0" Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="0"
                        Margin="0,0,16,0">
                    <Grid>
                        <!-- Header row -->
                        <Grid Margin="16,12,16,8" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lista de repartidores"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="txtBuscar" Grid.Column="2"
                                     Width="200" Height="28"
                                     Background="{DynamicResource InputBgBrush}"
                                     Foreground="{DynamicResource NavTextColor}"
                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                     BorderThickness="1" Padding="6,2" FontSize="12"
                                     TextChanged="TxtBuscar_TextChanged"/>
                        </Grid>

                        <!-- List -->
                        <ListBox x:Name="lstRepartidores" Margin="0,44,0,0"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionMode="Single"
                                 Foreground="{DynamicResource NavTextColor}"
                                 SelectionChanged="LstRepartidores_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" Margin="4,2"
                                            CornerRadius="8"
                                            Background="{DynamicResource POscuro2}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding EmpleadoNombre}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource NavTextColor}"/>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AcentoBrush}"
                                                        CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding EstadoDisplay}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Licencia: " FontSize="11"
                                                           Foreground="{DynamicResource SectionLabelColor}"/>
                                                <TextBlock Text="{Binding Licencia}" FontSize="11"
                                                           Foreground="{DynamicResource NavTextColor}"
                                                           Margin="0,0,16,0"/>
                                                <TextBlock Text="Zona: " FontSize="11"
                                                           Foreground="{DynamicResource SectionLabelColor}"/>
                                                <TextBlock Text="{Binding Zona}" FontSize="11"
                                                           Foreground="{DynamicResource NavTextColor}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock x:Name="txtEmptyState"
                                   Text="No hay repartidores registrados."
                                   Foreground="#888" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- ─── RIGHT: Form panel ─── -->
                <Border Grid.Column="1" Width="340"
                        Background="{DynamicResource FOscuro1}" CornerRadius="12" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock x:Name="txtFormTitle" Text="Nuevo Repartidor"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavTextColor}"
                                       Margin="0,0,0,12"/>

                            <!-- Empleado -->
                            <TextBlock Text="Empleado *" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbEmpleado"
                                      SelectedValuePath="Ci">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="{DynamicResource NavTextColor}"
                                                   Padding="6,4"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                            BorderThickness="0">
                                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <!-- Licencia -->
                            <TextBlock Text="N° Licencia *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtLicencia" Style="{StaticResource FormTextBox}" MaxLength="50"/>

                            <!-- Zona -->
                            <TextBlock Text="Zona de operación" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtZona" Style="{StaticResource FormTextBox}" MaxLength="100"/>

                            <!-- Estado -->
                            <TextBlock Text="Estado" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbEstado" Style="{StaticResource FormComboBox}" SelectedIndex="0">
                                <ComboBoxItem Content="Activo"/>
                                <ComboBoxItem Content="Inactivo"/>
                            </ComboBox>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="btnGuardar" Style="{StaticResource ActionButton}"
                                        Click="BtnGuardar_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💾" Margin="0,0,6,0"/>
                                        <TextBlock Text="Guardar"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="btnEliminar" Style="{StaticResource DangerButton}"
                                        Click="BtnEliminar_Click" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑" Margin="0,0,6,0"/>
                                        <TextBlock Text="Eliminar"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Button x:Name="btnCancelar" Style="{StaticResource SecondaryButton}"
                                    Click="BtnCancelar_Click" Margin="0,8,0,0">
                                <TextBlock Text="Cancelar"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
