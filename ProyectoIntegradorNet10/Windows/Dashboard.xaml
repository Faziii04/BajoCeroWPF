<Window x:Class="ProyectoIntegradorNet10.Windows.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.Windows"
        mc:Ignorable="d"
        Title="Dashboard" Height="800" Width="1280" Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Maximized">
            <Window.Resources>
                <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Margin="10,3">
                            <ContentPresenter HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A5A8A"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" Opacity="0.3" BlurRadius="8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3DAAD4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource SectionLabelColor}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="30,20,0,8"/>

        </Style>
    </Window.Resources>

    <Border Background="Transparent" CornerRadius="0" Margin="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Border Grid.Column="0" Grid.RowSpan="2"
            CornerRadius="0"
            Background="Transparent"
            Panel.ZIndex="1">

                <Grid>
                    <!-- Imagen día (modo claro) -->
                    <Image x:Name="imgFondoDia"
                       Source="/Images/diaFondoLogin.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Left"
                       Visibility="Collapsed"/>
                    <!-- Imagen noche (modo oscuro) -->
                    <Image x:Name="imgFondoNoche"
                       Source="/Images/nocheFondoLogin.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Left"
                       Visibility="Visible"/>

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>


                        <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False">
                            <Ellipse Canvas.Left="30" Canvas.Top="30" Width="160" Height="160" Fill="#FFFFFF" Opacity="0.08"/>
                            <Polygon Canvas.Right="30" Canvas.Bottom="30" Points="0,0 40,0 20,34" Fill="#FFFFFF" Opacity="0.05"/>
                        </Canvas>

                        <Grid Grid.Row="0" Panel.ZIndex="1">
                            <StackPanel Orientation="Horizontal" Margin="20,24,20,20">
                                <Border Width="48" Height="48" CornerRadius="24"
                        Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="1">
                                    <TextBlock Text="BC" FontSize="14" FontWeight="Bold"
                               Foreground="#1A4A7A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="BajoCero" FontSize="20" FontWeight="Bold"
                               Foreground="White"/>
                                    <TextBlock Text="Panel de control" FontSize="12"
                               Foreground="{DynamicResource SectionLabelColor}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Panel.ZIndex="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Height="1" Margin="0,0,0,12" CornerRadius="0.5" Background="{DynamicResource SeparatorColor}"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                                <StackPanel>

                                    <TextBlock Text="PRINCIPAL" Style="{StaticResource SectionLabelStyle}"/>

                                    <Button x:Name="navDashboard" Style="{StaticResource NavItemStyle}" Click="Button_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">




                                                <Rectangle Canvas.Left="0"  Canvas.Top="0"  Width="8" Height="8" Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="10" Canvas.Top="0"  Width="8" Height="8" Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="0"  Canvas.Top="10" Width="8" Height="8" Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="10" Canvas.Top="10" Width="8" Height="8" Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                            </Canvas>

                                            <TextBlock Text="Dashboard" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Productos -->
                                    <Button x:Name="navProductos" Style="{StaticResource NavItemStyle}" Click="NavProductos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="18" Height="18"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Polygon Points="5,6 15,6 10,14"
                                                         Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Productos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navProduccion" Style="{StaticResource NavItemStyle}" Click="NavProduccion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">

                                                <Polygon Points="10,1 19,9 19,19 1,19 1,9"

                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                <Rectangle Canvas.Left="7" Canvas.Top="12" Width="6" Height="7"

                                           Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                            </Canvas>

                                            <TextBlock Text="Producción" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navInsumos" Style="{StaticResource NavItemStyle}" Click="NavInsumos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="16" Height="16"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="6" Width="12" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="10" Width="8" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>

                                            <TextBlock Text="Insumos" Foreground="{DynamicResource NavTextColor}"
                                               FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Proveedores -->
                                    <Button x:Name="navProveedores" Style="{StaticResource NavItemStyle}" Click="NavProveedores_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="4" Width="18" Height="12"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="7" Width="12" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="11" Width="12" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Proveedores" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Órdenes de Compra -->
                                    <Button x:Name="navOrdenesCompra" Style="{StaticResource NavItemStyle}" Click="NavOrdenesCompra_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="18" Height="18"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Path Data="M 4,6 L 16,6 M 4,10 L 16,10 M 4,14 L 12,14"
                                                      Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                <Ellipse Canvas.Left="13" Canvas.Top="12" Width="5" Height="5"
                                                         Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Órdenes de Compra" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navInventario" Style="{StaticResource NavItemStyle}" Click="NavInventario_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="18" Height="18"

                                           Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                           StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="5" Canvas.Top="7" Width="10" Height="2"

                                           Fill="{DynamicResource NavTextColor}"/>
                                                <Ellipse Canvas.Left="3" Canvas.Top="6" Width="4" Height="4"

                                         Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="5" Canvas.Top="12" Width="10" Height="2"

                                           Fill="{DynamicResource NavTextColor}"/>
                                                <Ellipse Canvas.Left="3" Canvas.Top="11" Width="4" Height="4"

                                         Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>

                                            <TextBlock Text="Inventario" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>


                                    <Button x:Name="navDistribucion" Style="{StaticResource NavItemStyle}" Click="NavDistribucion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">

                                                <Rectangle Canvas.Left="1" Canvas.Top="5" Width="12" Height="10"

                                           Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                           StrokeThickness="1.5" RadiusX="1" RadiusY="1"/>
                                                <Polygon Points="13,8 19,8 19,15 13,15"

                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                <Ellipse Canvas.Left="3"  Canvas.Top="14" Width="4" Height="4"

                                         Fill="{DynamicResource NavTextColor}"/>
                                                <Ellipse Canvas.Left="14" Canvas.Top="14" Width="4" Height="4"

                                         Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>

                                            <TextBlock Text="Distribución" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>


                                    <Button x:Name="navClientes" Style="{StaticResource NavItemStyle}" Click="NavClientes_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Ellipse Canvas.Left="6" Canvas.Top="1" Width="8" Height="8"

                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                <Path Data="M 1,19 Q 2,13 10,13 Q 18,13 19,19"

                                      Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                                                                <Ellipse Canvas.Left="1" Canvas.Top="3" Width="6" Height="6" Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.2"/>
                                                                                            </Canvas>
                                                                                            <TextBlock Text="Clientes" Foreground="{DynamicResource NavTextColor}"
                                                                                                       FontSize="15" VerticalAlignment="Center"/>
                                                                                        </StackPanel>
                                                                                    </Button>

                                                                                    <!-- Préstamos -->
                                                                                    <Button x:Name="navPrestamos" Style="{StaticResource NavItemStyle}" Click="NavPrestamos_Click">
                                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                                                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="18" Height="18"
                                                                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                                                                <Path Data="M 4,6 L 16,6 M 4,10 L 16,10 M 4,14 L 16,14"
                                                                                                      Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.2"/>
                                                                                                <Ellipse Canvas.Left="7" Canvas.Top="7" Width="6" Height="6"
                                                                                                         Fill="{DynamicResource NavTextColor}"/>
                                                                                            </Canvas>
                                                                                            <TextBlock Text="Préstamos" Foreground="{DynamicResource NavTextColor}"
                                                                                                       FontSize="15" VerticalAlignment="Center"/>
                                                                                        </StackPanel>
                                                                                    </Button>

                                                                                    <!-- Empleados -->
                                                                                    <Button x:Name="navEmpleados" Style="{StaticResource NavItemStyle}" Click="NavEmpleados_Click">
                                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                                                                <Ellipse Canvas.Left="5" Canvas.Top="1" Width="10" Height="10"
                                                                                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                                                                <Path Data="M 2,19 Q 2,12 10,12 Q 18,12 18,19"
                                                                                                      Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                                                                <Ellipse Canvas.Left="1" Canvas.Top="3" Width="6" Height="6"
                                                                                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.2"/>
                                                                                            </Canvas>
                                                                                            <TextBlock Text="Empleados" Foreground="{DynamicResource NavTextColor}"
                                                                                                       FontSize="15" VerticalAlignment="Center"/>
                                                                                        </StackPanel>
                                                                                    </Button>

                                                                                    <Button x:Name="navVentasPagos" Style="{StaticResource NavItemStyle}" Click="NavVentasPagos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="4" Width="18" Height="13"

                                           Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                           StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="1" Canvas.Top="7" Width="18" Height="3"

                                           Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>

                                            <TextBlock Text="Ventas y pagos" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Facturación -->
                                    <Button x:Name="navFacturacion" Style="{StaticResource NavItemStyle}" Click="NavFacturacion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="18" Height="14"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="7" Width="12" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="11" Width="8" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Facturación" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="ANALISIS" Style="{StaticResource SectionLabelStyle}"/>

                                    <Button x:Name="navReportes" Style="{StaticResource NavItemStyle}" Click="NavReportes_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1"  Canvas.Top="12" Width="4" Height="7"

                                           Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="7"  Canvas.Top="8"  Width="4" Height="11"

                                           Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="13" Canvas.Top="4"  Width="4" Height="15"

                                           Fill="{DynamicResource NavTextColor}" RadiusX="1" RadiusY="1"/>
                                            </Canvas>

                                            <TextBlock Text="Reportes" Foreground="{DynamicResource NavTextColor}"
                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="ADMINISTRACIÓN" Style="{StaticResource SectionLabelStyle}"/>

                                    <!-- Roles y Permisos -->
                                    <Button x:Name="navRolesPermisos" Style="{StaticResource NavItemStyle}" Click="NavRolesPermisos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Ellipse Canvas.Left="6" Canvas.Top="1" Width="8" Height="8"
                                                         Fill="Transparent" Stroke="{DynamicResource NavTextColor}" StrokeThickness="1.5"/>
                                                <Rectangle Canvas.Left="3" Canvas.Top="10" Width="14" Height="9"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="1" RadiusY="1"/>
                                                <Rectangle Canvas.Left="5" Canvas.Top="12" Width="10" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Roles y Permisos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Vehículos -->
                                    <Button x:Name="navVehiculos" Style="{StaticResource NavItemStyle}" Click="NavVehiculos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="2" Canvas.Top="4" Width="16" Height="10"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Ellipse Canvas.Left="4" Canvas.Top="14" Width="4" Height="4"
                                                         Fill="{DynamicResource NavTextColor}"/>
                                                <Ellipse Canvas.Left="12" Canvas.Top="14" Width="4" Height="4"
                                                         Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="6" Canvas.Top="7" Width="8" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Vehículos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Depósitos -->
                                    <Button x:Name="navDepositos" Style="{StaticResource NavItemStyle}" Click="NavDepositos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="18" Height="14"
                                                          Fill="Transparent" Stroke="{DynamicResource NavTextColor}"
                                                          StrokeThickness="1.5" RadiusX="2" RadiusY="2"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="7" Width="12" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                                <Rectangle Canvas.Left="4" Canvas.Top="11" Width="8" Height="2"
                                                          Fill="{DynamicResource NavTextColor}"/>
                                                <Polygon Points="10,1 14,3 6,3"
                                                         Fill="{DynamicResource NavTextColor}"/>
                                            </Canvas>
                                            <TextBlock Text="Depósitos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Separator before logout -->
                                    <Border Height="1" Margin="20,10,20,10" CornerRadius="0.5" Background="{DynamicResource SeparatorColor}"/>

                                    <!-- Logout button -->
                                    <Button Style="{StaticResource NavItemStyle}" Click="btnLogout_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="20" Height="20" Margin="0,0,12,0">
                                                <Path Data="M 3,3 L 17,17 M 17,3 L 3,17"
                                                      Stroke="{DynamicResource NavTextColor}" StrokeThickness="2"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                            <TextBlock Text="Cerrar sesión" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>


            <Border Grid.Column="1" Grid.Row="0"
            Background="{DynamicResource BarraBrush}"
            Height="62"
            CornerRadius="0"
            Panel.ZIndex="1"
            MouseDown="TitleBar_MouseDown">
                <Grid>

                    <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Name="txtHora" Foreground="{DynamicResource NavTextColor}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
                        <!-- Photo or initial avatar -->
                        <Border Width="42" Height="42" CornerRadius="21"
                                Background="{DynamicResource AcentoBrush}"
                                Margin="0,0,12,0">
                            <Grid>
                                <Image x:Name="imgUsuario"
                                       Width="42" Height="42"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                                <TextBlock x:Name="txtInicialUsuario"
                                           Text="A"
                                           Foreground="White"
                                           FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="txtNombreUsuario"
                                       Text="usuario"
                                       Foreground="{DynamicResource NavTextColor}"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="txtEmailUsuario"
                                       Text="correo@ejemplo.com"
                                       Foreground="{DynamicResource SectionLabelColor}"
                                       FontSize="11" Margin="0,1,0,3"/>
                            <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left"
                                    Background="{DynamicResource AcentoBrush}">
                                <TextBlock x:Name="txtRolUsuario"
                                           Text="Administrador"
                                           Foreground="White"
                                           FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center">
                        <!-- Theme toggle -->
                        <Border CornerRadius="10" Background="{DynamicResource AcentoBrush}" Padding="10,5" Margin="0,0,4,0">
                            <Button Name="btnModo"
                            Content="☀ Modo"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="btnModo_Click"/>
                        </Border>

                        <!-- Window control buttons -->
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnMinimize"
                            Content="─"
                            Background="Transparent"
                            Foreground="{DynamicResource NavTextColor}"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="btnMinimize_Click"
                            ToolTip="Minimize"/>
                        </Border>
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnMaximize"
                            Content="□"
                            Background="Transparent"
                            Foreground="{DynamicResource NavTextColor}"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="btnMaximize_Click"
                            ToolTip="Maximize"/>
                        </Border>
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnClose"
                            Content="✕"
                            Background="Transparent"
                            Foreground="{DynamicResource NavTextColor}"
                            BorderThickness="0"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="btnClose_Click"
                            ToolTip="Close"/>
                        </Border>
                    </StackPanel>

                    <Canvas IsHitTestVisible="False">
                        <Ellipse Canvas.Right="10" Canvas.Top="10" Width="80" Height="80" Fill="#FFFFFF" Opacity="0.1"/>
                    </Canvas>
                </Grid>
            </Border>


            <Border Grid.Column="1" Grid.Row="1"
            Background="{DynamicResource FOscuro1}"
            CornerRadius="0">
                <Grid>
                    <Canvas IsHitTestVisible="False">
                        <Rectangle Canvas.Right="30" Canvas.Top="30" Width="160" Height="160" Fill="#3DAAD4" Opacity="0.06" RadiusX="30" RadiusY="30"/>
                        <Polygon Canvas.Left="40" Canvas.Bottom="60" Points="0,0 40,0 20,35" Fill="#1A4A7A" Opacity="0.04"/>
                    </Canvas>
                </Grid>
            </Border>
            <Border CornerRadius="0" Grid.Column="1" Grid.Row="1" Background="Transparent">
                <ContentControl x:Name="Contenido" Margin="0"></ContentControl>
            </Border>
        </Grid>
    </Border>
</Window>
