<Window x:Class="ProyectoIntegradorNet10.Windows.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoIntegradorNet10.Windows"
        mc:Ignorable="d"
        Title="Dashboard" Height="800" Width="1280" Background="Transparent" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Maximized">
    <Window.Resources>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- NAVIGATION BUTTON STYLE                                           -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Margin="10,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ActiveBar"
                                        Grid.Column="0"
                                        Background="{DynamicResource AcentoBrush}"
                                        CornerRadius="2"
                                        Width="0"
                                        HorizontalAlignment="Left"/>
                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                <Setter TargetName="Bd" Property="Effect" Value="{DynamicResource NavHoverShadow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- SECTION HEADER STYLE                                              -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SectionLabelColor}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="30,18,0,6"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

    </Window.Resources>

    <Border Background="Transparent" CornerRadius="0" Margin="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!-- SIDEBAR                                                          -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Grid.RowSpan="2"
                    CornerRadius="0"
                    Background="Transparent"
                    Panel.ZIndex="1">
                <Grid>
                    <!-- Background images -->
                    <Image x:Name="imgFondoDia"
                           Source="/Images/diaFondoLogin.png"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Left"
                           Visibility="Collapsed"/>
                    <Image x:Name="imgFondoNoche"
                           Source="/Images/nocheFondoLogin.png"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Left"
                           Visibility="Visible"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Decorative overlay -->
                        <Canvas Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False">
                            <Ellipse Canvas.Left="30" Canvas.Top="90" Width="160" Height="160"
                                     Fill="{DynamicResource NavTextColor}" Opacity="0.06"/>
                            <Polygon Canvas.Right="30" Canvas.Bottom="100" Points="0,0 40,0 20,34"
                                     Fill="{DynamicResource NavTextColor}" Opacity="0.04"/>
                        </Canvas>

                        <!-- ════════ TOP SECTION: Brand + Employee ════════ -->
                        <StackPanel Grid.Row="0" Panel.ZIndex="1" Margin="0,18,0,0">

                            <!-- Brand -->
                            <StackPanel Orientation="Horizontal" Margin="20,0,20,12">
                                <Border Width="52" Height="52" CornerRadius="18"
                                        Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="1.5">
                                    <TextBlock Text="BC" FontSize="16" FontWeight="Bold"
                                               Foreground="#1A4A7A"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="BajoCero" FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource NavTextColor}"/>
                                    <TextBlock Text="Panel de control" FontSize="10"
                                               Foreground="{DynamicResource SectionLabelColor}" Opacity="0.6"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Employee info (compact, secondary to brand) -->
                            <Border Background="#15FFFFFF" CornerRadius="12"
                                    Margin="20,0,20,0" Padding="12,8"
                                    BorderBrush="{DynamicResource SeparatorColor}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{DynamicResource AcentoBrush}"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <Image x:Name="imgUsuario"
                                                   Width="36" Height="36"
                                                   Stretch="UniformToFill"
                                                   Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtInicialUsuario"
                                                       Text="A"
                                                       Foreground="White"
                                                       FontSize="15" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Name + Role -->
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtNombreUsuario"
                                                   Text="usuario"
                                                   Foreground="{DynamicResource NavTextColor}"
                                                   FontSize="13" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                            <Border CornerRadius="3" Padding="5,1"
                                                    Background="{DynamicResource AcentoBrush}"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="txtRolUsuario"
                                                           Text="Administrador"
                                                           Foreground="White"
                                                           FontSize="8" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock x:Name="txtEmailUsuario"
                                                       Text="correo@ejemplo.com"
                                                       Foreground="{DynamicResource NavTextColor}" FontSize="9" Opacity="0.45"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>

                        <!-- ════════ NAVIGATION ════════ -->
                        <Grid Grid.Row="1" Panel.ZIndex="1" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Height="1" Margin="20,0,20,10" CornerRadius="0.5" Background="{DynamicResource SeparatorColor}"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>

                                    <TextBlock Text="PRINCIPAL" Style="{StaticResource SectionLabelStyle}"/>

                                    <Button x:Name="navProductos" Style="{StaticResource NavItemStyle}" Click="NavProductos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M2,2 L8,2 L8,8 L2,8 Z M12,2 L18,2 L18,8 L12,8 Z M7,7 L2,7 L2,13 L7,13 Z M7,7 L12,2 L17,7 L12,12 Z"/>
                                            <TextBlock Text="Productos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navProduccion" Style="{StaticResource NavItemStyle}" Click="NavProduccion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M10,2 L16,8 L16,17 L4,17 L4,8 Z M7,12 L13,12 M7,15 L10,15"/>
                                            <TextBlock Text="Producción" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navInsumos" Style="{StaticResource NavItemStyle}" Click="NavInsumos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M3,2 L17,2 C18,2 18,3 18,3 L18,17 C18,17 18,18 17,18 L3,18 C2,18 2,17 2,17 L2,3 C2,3 2,2 3,2 Z M6,7 L14,7 M6,10 L14,10 M6,13 L10,13"/>
                                            <TextBlock Text="Insumos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navProveedores" Style="{StaticResource NavItemStyle}" Click="NavProveedores_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M3,12 L3,18 L8,18 L8,11 M12,11 L12,18 L17,18 L17,12 M6,8 L10,4 L14,8 M10,4 L10,11"/>
                                            <TextBlock Text="Proveedores" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navOrdenesCompra" Style="{StaticResource NavItemStyle}" Click="NavOrdenesCompra_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M4,2 L14,2 C15,2 16,3 16,4 L16,17 C16,17 15,18 14,18 L4,18 C3,18 2,17 2,17 L2,4 C2,3 3,2 4,2 Z M6,7 L14,7 M6,10 L14,10 M6,13 L10,13"/>
                                            <TextBlock Text="Órdenes de Compra" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navInventario" Style="{StaticResource NavItemStyle}" Click="NavInventario_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M3,11 L3,17 L7,17 L7,11 M9,11 L9,17 L13,17 L13,11 M15,11 L15,17 L19,17 L19,11 M2,7 L20,7 M10,2 L10,7 M10,3 L16,3"/>
                                            <TextBlock Text="Inventario" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navDistribucion" Style="{StaticResource NavItemStyle}" Click="NavDistribucion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M2,12 L5,12 L7,7 L13,7 L15,12 L18,12 M7,7 L8,5 L12,5 L13,7 M3,14 L17,14 M4,17 L16,17 M6,17 L6,13 M14,17 L14,13"/>
                                            <TextBlock Text="Distribución" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navClientes" Style="{StaticResource NavItemStyle}" Click="NavClientes_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M7,5 C5.5,5 4,6.5 4,8 C4,9.5 5.5,10 7,10 C8.5,10 10,9.5 10,8 C10,6.5 8.5,5 7,5 Z M12,5 C10.5,5 9,6.5 9,8 C9,9.5 10.5,10 12,10 M2,15 C2,12.5 5,11 7,11 C9,11 12,12.5 12,15 M9,15 C9,13 11,12 12,12 C13.5,12 16,13 16,15"/>
                                            <TextBlock Text="Clientes" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navPrestamos" Style="{StaticResource NavItemStyle}" Click="NavPrestamos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M10,2 C13,2 15,4 15,7 C15,10 13,12 10,12 M10,2 C7,2 5,4 5,7 C5,10 7,12 10,12 M10,11 L10,17 M7,14 L13,14 M10,5 L10,10 M10,10 L7,7 M10,10 L13,7"/>
                                            <TextBlock Text="Préstamos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navEmpleados" Style="{StaticResource NavItemStyle}" Click="NavEmpleados_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M10,2 C7,2 5,4.5 5,7.5 C5,10.5 7,12 10,12 C13,12 15,10.5 15,7.5 C15,4.5 13,2 10,2 Z M4,17 C4,13 7,11 10,11 C13,11 16,13 16,17 M10,12 L10,15"/>
                                            <TextBlock Text="Empleados" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navVentasPagos" Style="{StaticResource NavItemStyle}" Click="NavVentasPagos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M10,2 C14,2 18,6 18,10 C18,14 14,18 10,18 C6,18 2,14 2,10 C2,6 6,2 10,2 Z M10,5 L10,15 M7,8 L13,8"/>
                                            <TextBlock Text="Ventas y pagos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navFacturacion" Style="{StaticResource NavItemStyle}" Click="NavFacturacion_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M3,2 L13,2 L17,6 L17,17 C17,17 16,18 15,18 L3,18 C2,18 1,17 1,17 L1,4 C1,3 2,2 3,2 Z M6,7 L12,7 M6,10 L12,10 M6,13 L10,13 M12,2 L12,6 L16,6"/>
                                            <TextBlock Text="Facturación" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="ANÁLISIS" Style="{StaticResource SectionLabelStyle}"/>

                                    <Button x:Name="navReportes" Style="{StaticResource NavItemStyle}" Click="NavReportes_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M3,17 L6,11 L9,14 L13,7 L17,13 L17,17 Z M13,4 L14,7 L17,7 L14.5,9 L15.5,12 L13,10.5 L10.5,12 L11.5,9 L9,7 L12,7 Z"/>
                                            <TextBlock Text="Reportes" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="ADMINISTRACIÓN" Style="{StaticResource SectionLabelStyle}"/>

                                    <Button x:Name="navRolesPermisos" Style="{StaticResource NavItemStyle}" Click="NavRolesPermisos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M10,2 C8,2 7,3.5 7,5 L7,7 L3,7 L3,17 L17,17 L17,7 L13,7 L13,5 C13,3.5 12,2 10,2 Z M10,10 L10,14 M10,14 L8,12 M10,14 L12,12"/>
                                            <TextBlock Text="Roles y Permisos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navVehiculos" Style="{StaticResource NavItemStyle}" Click="NavVehiculos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M2,12 L4,12 L6,7 L12,7 L14,12 L16,12 M5,7 L7,4 L11,4 L13,7 M3,13 L15,13 C14,16 4,16 3,13 Z M4,12 L5,8 M14,12 L13,8"/>
                                            <TextBlock Text="Vehículos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="navDepositos" Style="{StaticResource NavItemStyle}" Click="NavDepositos_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="18" Height="18" Margin="0,0,12,0"
                                                  Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                                  StrokeThickness="1.2" Fill="Transparent"
                                                  Data="M2,9 L10,3 L18,9 M2,9 L2,18 L7,18 L7,12 L13,12 L13,18 L18,18 L18,9 M5,18 L5,14 M15,18 L15,14"/>
                                            <TextBlock Text="Depósitos" Foreground="{DynamicResource NavTextColor}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- ════════ SIDEBAR FOOTER: Theme pill + Logout ════════ -->
                        <Border Grid.Row="2" Panel.ZIndex="1"
                                Background="#15000000"
                                CornerRadius="0"
                                Padding="16,10,16,14"
                                Margin="0,4,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Theme toggle pill (prominent accent button) -->
                                <Button Grid.Row="0" Name="btnModo"
                                        Height="42"
                                        Background="{DynamicResource AcentoBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="btnModo_Click"
                                        Effect="{DynamicResource CardHoverShadow}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="12"
                                                    BorderThickness="0"
                                                    Effect="{TemplateBinding Effect}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="txtModoIcon" Text="🌙" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="txtModoTexto" Text="Modo oscuro" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Divider -->
                                <Border Grid.Row="1" Height="1" Margin="0,10,0,8" CornerRadius="0.5" Background="{DynamicResource SeparatorColor}" Opacity="0.5"/>

                                <!-- Logout (subtle, centered) -->
                                <Button Grid.Row="1" Name="btnLogout"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        HorizontalAlignment="Center"
                                        Click="btnLogout_Click"
                                        ToolTip="Cerrar sesión"
                                        Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="16" Height="16"
                                              Stretch="Uniform" Stroke="{DynamicResource NavTextColor}"
                                              StrokeThickness="1.5" Fill="Transparent"
                                              Data="M9,3 L9,10 M3,7 C3,4 5.5,2 9,2 C12.5,2 15,4 15,7 M12,4 L15,7 L12,10"
                                              Margin="0,0,6,0"/>
                                        <TextBlock Text="Cerrar sesión" Foreground="{DynamicResource NavTextColor}"
                                                   FontSize="12" Opacity="0.6"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!-- TOP BAR (clean — only title, time, and window controls)        -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1" Grid.Row="0"
                    Background="{DynamicResource BarraBrush}"
                    Height="62"
                    CornerRadius="0"
                    Panel.ZIndex="1"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="24,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtTituloPagina" Text="Inicio"
                                   Foreground="{DynamicResource NavTextColor}"
                                   FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " Foreground="{DynamicResource SectionLabelColor}"
                                   FontSize="18" VerticalAlignment="Center" Opacity="0.4"/>
                        <TextBlock x:Name="txtHora" Foreground="{DynamicResource SectionLabelColor}"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnMinimize"
                                    Content="─"
                                    Background="Transparent"
                                    Foreground="{DynamicResource NavTextColor}"
                                    BorderThickness="0"
                                    FontSize="16" FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="btnMinimize_Click"
                                    ToolTip="Minimizar"/>
                        </Border>
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnMaximize"
                                    Content="□"
                                    Background="Transparent"
                                    Foreground="{DynamicResource NavTextColor}"
                                    BorderThickness="0"
                                    FontSize="14" FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="btnMaximize_Click"
                                    ToolTip="Maximizar"/>
                        </Border>
                        <Border Width="36" Height="36" CornerRadius="8" Background="Transparent" Margin="2,0">
                            <Button Name="btnClose"
                                    Content="✕"
                                    Background="Transparent"
                                    Foreground="{DynamicResource NavTextColor}"
                                    BorderThickness="0"
                                    FontSize="14" FontWeight="Bold"
                                    Cursor="Hand"
                                    Click="btnClose_Click"
                                    ToolTip="Cerrar"/>
                        </Border>
                    </StackPanel>

                    <Canvas IsHitTestVisible="False">
                        <Ellipse Canvas.Right="10" Canvas.Top="10" Width="80" Height="80" Fill="#FFFFFF" Opacity="0.1"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!-- CONTENT BACKGROUND + HOST                                        -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1" Grid.Row="1"
                    Background="{DynamicResource FOscuro1}"
                    CornerRadius="0">
                <Grid>
                    <Canvas IsHitTestVisible="False">
                        <Rectangle Canvas.Right="30" Canvas.Top="30" Width="160" Height="160"
                                   Fill="#3DAAD4" Opacity="0.06" RadiusX="30" RadiusY="30"/>
                        <Polygon Canvas.Left="40" Canvas.Bottom="60" Points="0,0 40,0 20,35"
                                 Fill="#1A4A7A" Opacity="0.04"/>
                    </Canvas>
                </Grid>
            </Border>
            <Border CornerRadius="0" Grid.Column="1" Grid.Row="1" Background="Transparent">
                <ContentControl x:Name="Contenido" Margin="16,8,16,16" Opacity="0"/>
            </Border>
        </Grid>
    </Border>
</Window>
