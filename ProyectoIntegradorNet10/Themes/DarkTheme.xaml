<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- DARK THEME COLORS -->
    <Color x:Key="FondoOscuro">#0D1B2A</Color>
    <Color x:Key="PanelOscuro">#1A2E42</Color>
    <Color x:Key="LetraOscuro">#FFFFFF</Color>
    <Color x:Key="BarraColor">#0D1B2A</Color>
    <Color x:Key="AcentoColor">#1A2E42</Color>
    <Color x:Key="NavColor">#F39C12</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="FOscuro1" Color="{DynamicResource FondoOscuro}"/>
    <SolidColorBrush x:Key="POscuro2" Color="{DynamicResource PanelOscuro}"/>
    <SolidColorBrush x:Key="LOscuro2" Color="{DynamicResource LetraOscuro}"/>
    <SolidColorBrush x:Key="BarraBrush" Color="{DynamicResource BarraColor}"/>
    <SolidColorBrush x:Key="AcentoBrush" Color="{DynamicResource AcentoColor}"/>
    <SolidColorBrush x:Key="NavTextColor" Color="{DynamicResource NavColor}"/>
    <SolidColorBrush x:Key="SectionLabelColor" Color="#7AAAC8"/>
    <SolidColorBrush x:Key="SeparatorColor" Color="#2A5A8A"/>

</ResourceDictionary>