<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- DARK THEME COLORS -->
    <Color x:Key="FondoOscuro">#0D1B2A</Color>
    <Color x:Key="PanelOscuro">#1A2E42</Color>
    <Color x:Key="LetraOscuro">#FFFFFF</Color>
    <Color x:Key="BarraColor">#0D1B2A</Color>
    <Color x:Key="AcentoColor">#1A2E42</Color>
    <Color x:Key="NavColor">#FFFFFF</Color>

    <!-- DataGrid-specific colors -->
    <Color x:Key="GridRowAltColor">#152238</Color>
    <Color x:Key="GridRowHoverColor">#1E3A5F</Color>
    <Color x:Key="GridRowSelectedColor">#2A5A8A</Color>
    <Color x:Key="GridHeaderColor">#152238</Color>
    <Color x:Key="InputBgColor">#0F1F30</Color>
    <Color x:Key="InputBorderColor">#2A5A8A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="FOscuro1" Color="{DynamicResource FondoOscuro}"/>
    <SolidColorBrush x:Key="POscuro2" Color="{DynamicResource PanelOscuro}"/>
    <SolidColorBrush x:Key="LOscuro2" Color="{DynamicResource LetraOscuro}"/>
    <SolidColorBrush x:Key="BarraBrush" Color="{DynamicResource BarraColor}"/>
    <SolidColorBrush x:Key="AcentoBrush" Color="{DynamicResource AcentoColor}"/>
    <SolidColorBrush x:Key="NavTextColor" Color="{DynamicResource NavColor}"/>
    <SolidColorBrush x:Key="SectionLabelColor" Color="#7AAAC8"/>
    <SolidColorBrush x:Key="SeparatorColor" Color="#2A5A8A"/>

    <SolidColorBrush x:Key="GridRowAltBrush" Color="{DynamicResource GridRowAltColor}"/>
    <SolidColorBrush x:Key="GridRowHoverBrush" Color="{DynamicResource GridRowHoverColor}"/>
    <SolidColorBrush x:Key="GridRowSelectedBrush" Color="{DynamicResource GridRowSelectedColor}"/>
    <SolidColorBrush x:Key="GridHeaderBrush" Color="{DynamicResource GridHeaderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{DynamicResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource InputBorderColor}"/>

    <!-- SOAT Status Colors -->
    <SolidColorBrush x:Key="SoatVigenteBrush" Color="#2ECC71"/>
    <SolidColorBrush x:Key="SoatPorVencerBrush" Color="#F1C40F"/>
    <SolidColorBrush x:Key="SoatVencidoBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="SoatVigenteBgBrush" Color="#1A2E1A"/>
    <SolidColorBrush x:Key="SoatPorVencerBgBrush" Color="#2E2E1A"/>
    <SolidColorBrush x:Key="SoatVencidoBgBrush" Color="#2E1A1A"/>

</ResourceDictionary>