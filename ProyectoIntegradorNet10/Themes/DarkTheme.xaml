<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- DARK THEME COLORS -->
    <Color x:Key="FondoOscuro">#0D1B2A</Color>
    <Color x:Key="PanelOscuro">#1A2E42</Color>
    <Color x:Key="LetraOscuro">#FFFFFF</Color>
    <Color x:Key="BarraColor">#0D1B2A</Color>
    <Color x:Key="AcentoColor">#2A5A8A</Color>
    <Color x:Key="NavColor">#FFFFFF</Color>

    <!-- DataGrid-specific colors -->
    <Color x:Key="GridRowAltColor">#152238</Color>
    <Color x:Key="GridRowHoverColor">#1E3A5F</Color>
    <Color x:Key="GridRowSelectedColor">#2A5A8A</Color>
    <Color x:Key="GridHeaderColor">#152238</Color>
    <Color x:Key="InputBgColor">#0F1F30</Color>
    <Color x:Key="InputBorderColor">#2A5A8A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="FOscuro1" Color="{DynamicResource FondoOscuro}"/>
    <SolidColorBrush x:Key="POscuro2" Color="{DynamicResource PanelOscuro}"/>
    <SolidColorBrush x:Key="LOscuro2" Color="{DynamicResource LetraOscuro}"/>
    <SolidColorBrush x:Key="BarraBrush" Color="{DynamicResource BarraColor}"/>
    <SolidColorBrush x:Key="AcentoBrush" Color="{DynamicResource AcentoColor}"/>
    <SolidColorBrush x:Key="NavTextColor" Color="{DynamicResource NavColor}"/>
    <SolidColorBrush x:Key="SectionLabelColor" Color="#7AAAC8"/>
    <SolidColorBrush x:Key="SeparatorColor" Color="#2A5A8A"/>

    <SolidColorBrush x:Key="GridRowAltBrush" Color="{DynamicResource GridRowAltColor}"/>
    <SolidColorBrush x:Key="GridRowHoverBrush" Color="{DynamicResource GridRowHoverColor}"/>
    <SolidColorBrush x:Key="GridRowSelectedBrush" Color="{DynamicResource GridRowSelectedColor}"/>
    <SolidColorBrush x:Key="GridHeaderBrush" Color="{DynamicResource GridHeaderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{DynamicResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{DynamicResource InputBorderColor}"/>

    <!-- SOAT Status Colors -->
    <SolidColorBrush x:Key="SoatVigenteBrush" Color="#2ECC71"/>
    <SolidColorBrush x:Key="SoatPorVencerBrush" Color="#F1C40F"/>
    <SolidColorBrush x:Key="SoatVencidoBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="SoatVigenteBgBrush" Color="#1A2E1A"/>
    <SolidColorBrush x:Key="SoatPorVencerBgBrush" Color="#2E2E1A"/>
    <SolidColorBrush x:Key="SoatVencidoBgBrush" Color="#2E1A1A"/>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- GLOBAL DARK MODE FIXES: ComboBox, DatePicker, Calendar          -->
    <!-- ════════════════════════════════════════════════════════════════ -->

    <!-- ─── ComboBox ─── -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Border" Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>
                        <!-- Editable text box -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Margin="{TemplateBinding Padding}"
                                 Background="Transparent"
                                 Foreground="{TemplateBinding Foreground}"
                                 BorderThickness="0"
                                 FontSize="{TemplateBinding FontSize}"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="{TemplateBinding Foreground}"
                                 Visibility="Collapsed"/>
                        <!-- Selection text -->
                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <!-- Toggle button -->
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.Column="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Width="24"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Cursor="Hand"
                                      Style="{x:Null}"
                                      VerticalAlignment="Center">
                            <Path x:Name="Arrow" Data="M0,0 L5,5 L10,0"
                                  Fill="{DynamicResource SectionLabelColor}"
                                  Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ToggleButton>
                        <!-- Popup -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               AllowsTransparency="True" Placement="Bottom"
                               PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}">
                                <Border Background="{DynamicResource POscuro2}"
                                        BorderBrush="{DynamicResource SeparatorColor}"
                                        BorderThickness="1" CornerRadius="8" Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── ComboBoxItem ─── -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ─── DatePicker ─── -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ─── DatePickerTextBox (internal text part) ─── -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ─── Calendar / DatePicker popup ─── -->
    <Style TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SeparatorColor}"/>
    </Style>
    <Style TargetType="CalendarItem">
        <Setter Property="Background" Value="{DynamicResource POscuro2}"/>
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
    </Style>
    <Style TargetType="CalendarDayButton">
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AcentoBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsToday" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AcentoBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="CalendarButton">
        <Setter Property="Foreground" Value="{DynamicResource NavTextColor}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridRowHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridRowSelectedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>